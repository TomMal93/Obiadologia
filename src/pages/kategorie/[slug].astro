---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import RecipeCard from "@components/RecipeCard.astro";
import {
  getCategoryRecipes,
  recipeCategories,
  type RecipeCategory
} from "../../lib/categories";

export function getStaticPaths() {
  return recipeCategories.map((category) => ({
    params: { slug: category.slug },
    props: { category }
  }));
}

interface Props {
  category: RecipeCategory;
}

const { category } = Astro.props;
const recipes = await getCollection("recipes");
const categoryRecipes = getCategoryRecipes(recipes, category);
---

<BaseLayout
  title={`Obiadologia - ${category.title}`}
  description={category.description}
  questions={[category.shortTitle, ...category.suggestions, "wszystkie przepisy"]}
>
  <section class="hero category-hero">
    <div class="category-copy">
      <p class="eyebrow">Kategoria</p>
      <h1>{category.title}<span>.</span></h1>
      <p class="lead">{category.description}</p>
    </div>
  </section>

  <section class="category-layout">
    {categoryRecipes.length > 0 ? (
      <div class="recipe-grid">
        {categoryRecipes.map((recipe, index) => <RecipeCard recipe={recipe} index={index} fullWidthContent />)}
      </div>
    ) : (
      <p class="empty-state">Ta kategoria czeka jeszcze na pierwsze przepisy.</p>
    )}
  </section>

  <section class="category-return" aria-label="Powrót do wyboru kategorii">
    <a href="/#tryby">Powrót do wyboru kategorii</a>
  </section>
</BaseLayout>

<style>
  .category-hero {
    padding-bottom: 18px;
  }

  .category-copy {
    margin-top: clamp(2px, 2vw, 18px);
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 12px;
    font-weight: 950;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .category-copy h1 {
    max-width: 820px;
  }

  .category-copy h1 span {
    color: var(--accent);
  }

  .category-layout {
    margin-top: 20px;
  }

  .recipe-grid {
    display: grid;
    gap: 12px;
  }

  .empty-state {
    margin: 0;
    padding: 18px;
    border-radius: 24px;
    background: rgba(255, 253, 248, 0.88);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 14px;
    font-weight: 850;
    text-align: center;
  }

  .category-return {
    margin-top: 28px;
    display: flex;
    justify-content: center;
  }

  .category-return a {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    background: var(--text);
    color: white;
    font-size: 13px;
    font-weight: 950;
    box-shadow: 0 14px 30px rgba(37, 26, 20, 0.14);
  }

  @media (min-width: 700px) {
    .recipe-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .recipe-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
