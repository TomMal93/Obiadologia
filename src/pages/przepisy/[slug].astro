---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");
  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe }
  }));
}

interface Props {
  recipe: CollectionEntry<"recipes">;
}

const { recipe } = Astro.props;
const titleParts = recipe.data.title.split(" i ");
const displayTitle = titleParts.length > 1
  ? `${titleParts.slice(0, -1).join(" i ")} i `
  : recipe.data.title;
const accentTitle = titleParts.length > 1 ? `${titleParts.at(-1)}.` : "";

const schema = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  name: recipe.data.title,
  description: recipe.data.description,
  recipeYield: `${recipe.data.servings} porcje`,
  totalTime: `PT${recipe.data.timeMinutes}M`,
  recipeIngredient: recipe.data.ingredients.map((item) => `${item.name} - ${item.amount}`),
  recipeInstructions: recipe.data.steps.map((step) => ({
    "@type": "HowToStep",
    name: step.title,
    text: step.text
  })),
  keywords: recipe.data.tags.join(", ")
};
---

<BaseLayout
  title={`Obiadologia - ${recipe.data.title}`}
  description={recipe.data.description}
  compactMain
  schema={schema}
  questions={[
    "co dziś na obiad?",
    `${recipe.data.timeMinutes} minut i gotowe`,
    recipe.data.effort,
    recipe.data.tags[0] ?? "prosty przepis",
    "mam jajka",
    "warzywa z lodówki",
    "bez kombinowania",
    "obiad na szybko",
    "co zjemy?",
    "mało zmywania",
    "robię to",
    "prosty przepis"
  ]}
>
  <a class="back-link" href="/przepisy">← Wróć do propozycji</a>

  <section class="recipe-hero">
    <article class="recipe-intro">
      <div class="eyebrow">Przepis · {recipe.data.mood}</div>

      <h1>{displayTitle}{accentTitle && <span>{accentTitle}</span>}</h1>

      <p class="lead">{recipe.data.description}</p>

      <div class="meta-row">
        <span class="meta">{recipe.data.timeMinutes} min</span>
        <span class="meta">{recipe.data.effort}</span>
        <span class="meta">{recipe.data.servings} porcje</span>
        <span class="meta">{recipe.data.difficulty}</span>
      </div>

      <div class="hero-actions">
        <a class="primary-button" href="#kroki">Robię to</a>
        <a class="secondary-button" href="#skladniki">Sprawdź składniki</a>
      </div>
    </article>

    <aside class="dish-card" aria-label="Ilustracja dania">
      <div class="dish-visual"></div>
      <div class="quick-note">Najlepiej potraktuj przepis jak plan, nie egzamin. Zamień składniki na to, co masz.</div>
    </aside>
  </section>

  <section class="content-grid">
    <aside class="side-stack">
      <article class="panel" id="skladniki">
        <h2>Składniki</h2>

        <ul class="ingredients">
          {recipe.data.ingredients.map((item) => (
            <li><strong>{item.name}</strong><span>{item.amount}</span></li>
          ))}
        </ul>
      </article>

      <article class="small-card">
        <h3>Zamienniki</h3>
        <p>Trzymaj się sposobu przygotowania, ale składniki możesz wymienić na najbliższe rzeczy z lodówki.</p>
        <div class="chips">
          {recipe.data.tags.slice(0, 3).map((tag) => <span class="chip">{tag}</span>)}
        </div>
      </article>

      <article class="small-card">
        <h3>Dobre dodatki</h3>
        <p>Na końcu dorzuć coś świeżego, chrupiącego albo kwaśnego. To często robi cały obiad.</p>
        <div class="chips">
          <span class="chip">szczypiorek</span>
          <span class="chip">chili</span>
          <span class="chip">jogurt</span>
        </div>
      </article>
    </aside>

    <article class="panel" id="kroki">
      <h2>Kroki</h2>

      <ol class="steps">
        {recipe.data.steps.map((step) => (
          <li>
            <strong>{step.title}</strong>
            {step.text}
          </li>
        ))}
      </ol>
    </article>
  </section>

  <section class="cta-card">
    <div>
      <h2>Nie ten obiad?</h2>
      <p>Wróć do decyzyjnika i wybierz coś szybszego, tańszego albo bez mięsa.</p>
    </div>

    <a class="cta-button" href="/">Znajdź inny pomysł</a>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    padding: 9px 13px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.72);
    color: var(--muted);
    font-size: 13px;
    font-weight: 950;
    backdrop-filter: blur(12px);
  }

  .recipe-hero {
    display: grid;
    gap: 14px;
  }

  .recipe-intro {
    padding: 18px;
  }

  .recipe-intro .eyebrow {
    margin: 0 0 14px;
    background: var(--soft);
    box-shadow: none;
  }

  .recipe-intro h1 {
    margin: 0;
    max-width: 720px;
    font-size: clamp(44px, 13vw, 78px);
  }

  .recipe-intro .lead {
    margin: 18px 0 0;
    max-width: 620px;
    text-align: left;
  }

  .recipe-intro .meta-row {
    margin-top: 22px;
  }

  .recipe-intro .meta {
    padding: 8px 11px;
    font-size: 12px;
  }

  .hero-actions {
    display: grid;
    gap: 10px;
    margin-top: 20px;
  }

  .dish-card {
    position: relative;
    min-height: 260px;
    padding: 16px;
    overflow: hidden;
  }

  .dish-visual {
    position: relative;
    min-height: 228px;
    border-radius: 23px;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 253, 248, 0.96) 0 30%, transparent 31%),
      radial-gradient(circle at 40% 44%, #ffd79a 0 7%, transparent 8%),
      radial-gradient(circle at 58% 42%, #ff795f 0 6%, transparent 7%),
      radial-gradient(circle at 49% 58%, #2f8f5b 0 5%, transparent 6%),
      radial-gradient(circle at 62% 60%, #ffc857 0 5%, transparent 6%),
      linear-gradient(135deg, #ffe5b8, #ffc857);
    border: 1px solid rgba(37, 26, 20, 0.08);
    overflow: hidden;
  }

  .dish-visual::before {
    content: "";
    position: absolute;
    inset: 42px;
    border-radius: 999px;
    border: 18px solid rgba(255, 253, 248, 0.9);
    box-shadow: 0 22px 50px rgba(37, 26, 20, 0.12);
  }

  .dish-visual::after {
    content: "🍳";
    position: absolute;
    right: 20px;
    bottom: 18px;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    background: var(--accent);
    color: white;
    font-size: 24px;
    box-shadow: 0 14px 30px rgba(255, 90, 61, 0.28);
  }

  .quick-note {
    position: absolute;
    left: 28px;
    bottom: 28px;
    max-width: 190px;
    padding: 12px;
    border-radius: 18px;
    background: rgba(255, 253, 248, 0.88);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 12px;
    line-height: 1.35;
    font-weight: 850;
    backdrop-filter: blur(10px);
  }

  .content-grid {
    display: grid;
    gap: 18px;
    margin-top: 28px;
    align-items: start;
  }

  .panel {
    padding: 18px;
    border-radius: var(--radius-lg);
    background: rgba(255, 253, 248, 0.88);
    border: 1px solid var(--border);
    box-shadow: 0 12px 34px rgba(37, 26, 20, 0.08);
    backdrop-filter: blur(14px);
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .panel h2 {
    margin: 0 0 16px;
    font-size: 32px;
    letter-spacing: -0.065em;
    line-height: 0.95;
  }

  .ingredients {
    display: grid;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .ingredients li {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px;
    border-radius: 17px;
    background: var(--soft);
    color: var(--muted);
    font-size: 14px;
    font-weight: 850;
  }

  .ingredients strong {
    color: var(--text);
    font-weight: 950;
  }

  .steps {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
    counter-reset: step;
  }

  .steps li {
    position: relative;
    padding: 16px 16px 16px 58px;
    border-radius: 20px;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 14px;
    line-height: 1.45;
  }

  .steps li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 14px;
    top: 14px;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: var(--text);
    color: white;
    font-size: 13px;
    font-weight: 950;
  }

  .steps strong {
    display: block;
    margin-bottom: 4px;
    color: var(--text);
    font-size: 16px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .side-stack {
    display: grid;
    gap: 14px;
  }

  .small-card {
    padding: 16px;
    border-radius: 24px;
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 14px 38px rgba(37, 26, 20, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .small-card h3 {
    margin: 0;
    font-size: 22px;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .small-card p {
    margin: 9px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.45;
  }

  .small-card .chips {
    margin-top: 12px;
  }

  @media (min-width: 700px) {
    .hero-actions {
      grid-template-columns: auto auto;
      justify-content: start;
    }

    .primary-button,
    .secondary-button {
      min-width: 150px;
      padding: 0 22px;
    }

    .content-grid {
      grid-template-columns: 0.86fr 1.14fr;
    }
  }

  @media (min-width: 960px) {
    .recipe-hero {
      grid-template-columns: 1.05fr 0.95fr;
      align-items: stretch;
    }

    .recipe-intro,
    .dish-card {
      min-height: 430px;
    }

    .recipe-intro {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 28px;
    }

    .dish-visual { min-height: 396px; }
    .recipe-intro .lead { font-size: 19px; }
  }
</style>
