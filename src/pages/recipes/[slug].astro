---
import SiteHeader from '@/components/SiteHeader.astro';
import { prototypeRecipes } from '@/data/prototype-recipes';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Recipe } from '@/domain/recipe';
import { formatHouseholdMeasure, formatMetricMeasure } from '@/domain/ingredient';

export function getStaticPaths() {
  return prototypeRecipes
    .filter((recipe) => recipe.status === 'published')
    .map((recipe) => ({
      params: { slug: recipe.slug },
      props: { recipe },
    }));
}

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
---

<BaseLayout title={`${recipe.title} — Obiadologia`} description={recipe.description}>
  <SiteHeader />

  <main class="recipe-page">
    <article class="recipe-article">
      <div class="recipe-hero">
        {
          recipe.image ? (
            <img src={recipe.image.src} alt={recipe.image.alt} loading="eager" />
          ) : (
            <span class="recipe-placeholder" aria-hidden="true">O</span>
          )
        }
      </div>

      <header class="recipe-intro">
        <p class="eyebrow">Przepis</p>
        <h1>{recipe.title}</h1>
        <p class="recipe-lead">{recipe.description}</p>
      </header>

      <section class="recipe-ingredients" aria-labelledby="ingredients-heading">
        <div class="recipe-ingredients__head">
          <div class="recipe-ingredients__title-row">
            <h2 id="ingredients-heading">Składniki</h2>
            <p class="prep-time">
              <svg
                class="prep-time__icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3.5 2" />
              </svg>
              <span class="visually-hidden">Czas przygotowania:</span>{' '}
              <span class="prep-time__value">{recipe.preparationMinutes} min</span>
            </p>
          </div>
          <div class="unit-toggle" role="group" aria-label="Jednostki miary składników" hidden>
            <button
              type="button"
              class="unit-toggle__option is-active"
              data-units-target="metric"
              aria-pressed="true"
            >
              gramy / ml
            </button>
            <button
              type="button"
              class="unit-toggle__option"
              data-units-target="household"
              aria-pressed="false"
            >
              szklanki / szczypty
            </button>
          </div>
        </div>
        <ul class="ingredient-list" data-units="metric">
          {
            recipe.ingredients.map((ingredient) => (
              <li class="ingredient">
                <span class="ingredient__name">{ingredient.name}</span>
                <span class="ingredient__measure">
                  <span class="ingredient__measure-metric">{formatMetricMeasure(ingredient)}</span>
                  <span class="ingredient__measure-household">
                    {formatHouseholdMeasure(ingredient)}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </section>

      <p class="prototype-note">
        Dane przepisu pochodzą z prototypowego katalogu. Pełna treść redakcyjna (kroki
        przygotowania i zdjęcia) powstanie po wyborze źródła danych.
      </p>

      <a class="back-link" href="/">← Wróć do strony głównej</a>
    </article>
  </main>
</BaseLayout>

<style>
  /* Strona wypełnia ekran poniżej nagłówka; przy dłuższej treści (powiększenie
     tekstu, niski ekran) rośnie i przewija się zgodnie z regułą reflow. */
  .recipe-page {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - var(--header-block));
    min-height: calc(100dvh - var(--header-block));
    padding: 0 var(--gutter) var(--screen-pad-y);
  }

  .recipe-article {
    display: grid;
    gap: var(--stack-gap);
    padding: var(--space-16) var(--space-16) var(--space-24);
    border-radius: var(--radius-panel);
    background: var(--color-surface);
    box-shadow: var(--shadow-surface);
  }

  .recipe-hero {
    display: grid;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--radius-card);
  }

  .recipe-hero > img,
  .recipe-hero > span {
    width: 100%;
    height: 100%;
  }

  .recipe-hero > img {
    display: block;
    object-fit: cover;
  }

  .recipe-hero > span {
    font-size: clamp(48px, 14vw, 64px);
  }

  .recipe-intro {
    display: grid;
    gap: var(--space-8);
  }

  .recipe-intro h1 {
    margin: 0;
    font-size: clamp(28px, 7.5vw, 36px);
    line-height: 1.1;
  }

  .recipe-lead {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Czas przygotowania jako pigułka marki — nadaje metadanej własną, czytelną
     formę i stoi po prawej w wierszu nagłówka „Składniki”. Statyczny tekst, więc
     nie dotyczy go próg 44 × 44px obszaru akcji. */
  .prep-time {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    flex: none;
    margin: 0;
    padding: var(--space-8) var(--space-12);
    border-radius: var(--radius-pill);
    color: var(--color-coral-strong);
    font-weight: 700;
    background: var(--color-coral-soft);
  }

  .prep-time__icon {
    flex: none;
  }

  .prep-time__value {
    font-variant-numeric: tabular-nums;
  }

  /* Etykieta tylko dla czytnika ekranu — wizualnie niesie ją forma pigułki,
     ale znaczenie „czas przygotowania” pozostaje dostępne bez polegania na
     kolorze czy ikonie. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .recipe-ingredients__head {
    display: grid;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  /* Nagłówek sekcji i pigułka czasu w jednym wierszu: tytuł po lewej, czas po
     prawej. Przy wąskim ekranie pigułka zawija się pod tytuł bez ucięcia. */
  .recipe-ingredients__title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8) var(--space-12);
  }

  .recipe-ingredients__head h2 {
    margin: 0;
    font-size: var(--font-size-24);
    line-height: 1.2;
  }

  /* Przełącznik formy miary; ukryty do czasu włączenia przez skrypt, aby bez
     JS użytkownik widział sprawną listę w jednostkach metrycznych. */
  .unit-toggle {
    display: inline-flex;
    gap: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-pill);
    background: var(--color-bg);
  }

  .unit-toggle[hidden] {
    display: none;
  }

  .unit-toggle__option {
    display: inline-flex;
    min-height: 44px;
    flex: 1;
    align-items: center;
    justify-content: center;
    padding: var(--space-8) var(--space-12);
    border: 0;
    border-radius: var(--radius-pill);
    color: var(--color-text-muted);
    font-size: var(--font-size-14);
    font-weight: 700;
    background: transparent;
    cursor: pointer;
  }

  .unit-toggle__option.is-active {
    color: var(--color-search-strong);
    font-weight: 800;
    background: var(--color-surface);
    box-shadow: var(--shadow-surface);
  }

  .ingredient-list {
    display: grid;
    gap: var(--space-8);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ingredient {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    line-height: 1.5;
  }

  .ingredient:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .ingredient__measure {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Widoczna jest tylko forma pasująca do aktualnego stanu przełącznika. */
  .ingredient-list[data-units='metric'] .ingredient__measure-household,
  .ingredient-list[data-units='household'] .ingredient__measure-metric {
    display: none;
  }

  .prototype-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-14);
    line-height: 1.5;
  }

  .back-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: var(--space-4);
    justify-self: start;
    color: var(--color-cta-strong);
    font-weight: 800;
  }
</style>

<script>
  // Progresywne wzbogacenie: bez JS strona pokazuje sprawną listę w jednostkach
  // metrycznych, a przełącznik pozostaje ukryty. Skrypt go odsłania i przełącza
  // formę miary, przełączając wyłącznie klasę na liście (obie formy są w HTML).
  const toggle = document.querySelector<HTMLElement>('.unit-toggle');
  const list = document.querySelector<HTMLElement>('.ingredient-list');

  if (toggle && list) {
    toggle.hidden = false;
    const options = Array.from(toggle.querySelectorAll<HTMLButtonElement>('.unit-toggle__option'));

    for (const option of options) {
      option.addEventListener('click', () => {
        const target = option.dataset.unitsTarget;
        if (!target) return;
        list.dataset.units = target;
        for (const other of options) {
          const active = other === option;
          other.classList.toggle('is-active', active);
          other.setAttribute('aria-pressed', String(active));
        }
      });
    }
  }
</script>
