---
import SiteHeader from '@/components/SiteHeader.astro';
import { prototypeRecipes } from '@/data/prototype-recipes';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Recipe } from '@/domain/recipe';
import { formatHouseholdMeasure, formatMetricMeasure } from '@/domain/ingredient';
import { formatLeadTime } from '@/domain/recipe-schedule';
import { defaultLocale } from '@/i18n/config';
import { formatMessage } from '@/i18n/format';
import { getMessages } from '@/i18n/messages';
import './recipe-page.css';

export function getStaticPaths() {
  return prototypeRecipes
    .filter((recipe) => recipe.status === 'published')
    .map((recipe) => ({
      params: { slug: recipe.slug },
      props: { recipe },
    }));
}

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;
const messages = getMessages(defaultLocale);

// Sekcje wspierające gotowanie („Wcześniej” i „Przygotowanie”) są opcjonalne.
// Tryb asystenta ma sens tylko, gdy jest co pokazać poza samymi krokami —
// prostota przepisu wynika więc z pustych pól, bez osobnego przełącznika treści.
const hasAssistantContent = Boolean(recipe.advance || recipe.preparation);
---

<BaseLayout
  title={`${recipe.title} — ${messages.common.brand}`}
  description={recipe.description}
  locale={defaultLocale}
>
  <SiteHeader messages={messages.common} />

  <main class="recipe-page">
    <article
      class="recipe-article"
      data-view="assistant"
      data-start-previous-day={messages.recipe.startPreviousDay}
      data-start-same-day={messages.recipe.startSameDay}
    >
      <div class="recipe-hero">
        {
          recipe.image ? (
            <img src={recipe.image.src} alt={recipe.image.alt} loading="eager" />
          ) : (
            <span class="recipe-placeholder" aria-hidden="true">O</span>
          )
        }
      </div>

      <header class="recipe-intro">
        <div class="recipe-intro__top">
          <ul class="recipe-tags" aria-label={messages.common.tagsLabel}>
            {recipe.tags.map((tag) => <li>{tag}</li>)}
          </ul>
          <p class="prep-time">
            <svg
              class="prep-time__icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l3.5 2" />
            </svg>
            <span class="visually-hidden">{messages.recipe.preparationTimeLabel}</span>{' '}
            <span class="prep-time__value">
              {recipe.preparationMinutes} {messages.common.minuteAbbreviation}
            </span>
          </p>
        </div>
        <h1>{recipe.title}</h1>
        <p class="recipe-lead">{recipe.description}</p>
      </header>

      <section class="recipe-ingredients" aria-labelledby="ingredients-heading">
        <div class="recipe-ingredients__head">
          <h2 id="ingredients-heading">{messages.recipe.ingredientsHeading}</h2>
          <div class="unit-toggle" role="group" aria-label={messages.recipe.unitsLabel} hidden>
            <button
              type="button"
              class="unit-toggle__option is-active"
              data-units-target="metric"
              aria-pressed="true"
            >
              {messages.recipe.metricUnits}
            </button>
            <button
              type="button"
              class="unit-toggle__option"
              data-units-target="household"
              aria-pressed="false"
            >
              {messages.recipe.householdUnits}
            </button>
          </div>
        </div>
        <ul class="ingredient-list" data-units="metric">
          {
            recipe.ingredients.map((ingredient) => (
              <li class="ingredient">
                <span class="ingredient__name">{ingredient.name}</span>
                <span class="ingredient__measure">
                  <span class="ingredient__measure-metric">{formatMetricMeasure(ingredient)}</span>
                  <span class="ingredient__measure-household">
                    {formatHouseholdMeasure(ingredient)}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </section>

      {
        hasAssistantContent && (
          <div
            class="assistant-toggle"
            role="group"
            aria-label={messages.recipe.assistantLabel}
            hidden
          >
            <button
              type="button"
              class="assistant-toggle__option is-active"
              data-view-target="assistant"
              aria-pressed="true"
            >
              {messages.recipe.assistantMode}
            </button>
            <button
              type="button"
              class="assistant-toggle__option"
              data-view-target="steps"
              aria-pressed="false"
            >
              {messages.recipe.stepsOnlyMode}
            </button>
          </div>
        )
      }

      {
        recipe.advance && (
          <section
            class="recipe-advance assistant-section"
            aria-labelledby="advance-heading"
          >
            <div class="assistant-section__head">
              <h2 id="advance-heading">{messages.recipe.advanceHeading}</h2>
              <p class="assistant-section__hint">
                {messages.recipe.advanceHint}
              </p>
            </div>
            <div class="advance-calc" hidden>
              <label class="advance-calc__label" for="serve-time">
                {messages.recipe.serveTimeLabel}
              </label>
              <input class="advance-calc__input" id="serve-time" type="time" />
              <p class="advance-calc__hint">
                {messages.recipe.serveTimeHint}
              </p>
            </div>
            <ol class="advance-list">
              {recipe.advance.map((step) => (
                <li class="advance-step">
                  <p class="advance-step__text">{step.text}</p>
                  <p class="advance-step__timing">
                    <span class="advance-step__lead">
                      {formatMessage(messages.recipe.advanceTiming, {
                        time: formatLeadTime(step.leadTimeMinutes),
                      })}
                    </span>
                    <span
                      class="advance-step__start"
                      data-lead-minutes={step.leadTimeMinutes}
                      hidden
                    />
                  </p>
                </li>
              ))}
            </ol>
          </section>
        )
      }

      {
        recipe.preparation && (
          <section class="recipe-prep assistant-section" aria-labelledby="prep-heading">
            <div class="assistant-section__head">
              <h2 id="prep-heading">{messages.recipe.preparationHeading}</h2>
              <p class="assistant-section__hint">
                {messages.recipe.preparationHint}
              </p>
            </div>
            <ul class="prep-list">
              {recipe.preparation.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>
        )
      }

      <section class="recipe-steps" aria-labelledby="steps-heading">
        <h2 id="steps-heading">{messages.recipe.stepsHeading}</h2>
        <ol class="step-list">
          {recipe.steps.map((step) => <li>{step}</li>)}
        </ol>
      </section>

      <p class="prototype-note">
        {messages.recipe.prototypeNote}
      </p>

      <a class="back-link" href="/">{messages.recipe.backHome}</a>
    </article>
  </main>
</BaseLayout>

<script>
  import { formatClock, parseClock, scheduleAdvanceSteps } from '@/domain/recipe-schedule';

  // Progresywne wzbogacenie: bez JS strona pokazuje sprawną listę w jednostkach
  // metrycznych, a przełącznik pozostaje ukryty. Skrypt go odsłania i przełącza
  // formę miary, przełączając wyłącznie klasę na liście (obie formy są w HTML).
  const toggle = document.querySelector<HTMLElement>('.unit-toggle');
  const list = document.querySelector<HTMLElement>('.ingredient-list');

  if (toggle && list) {
    toggle.hidden = false;
    const options = Array.from(toggle.querySelectorAll<HTMLButtonElement>('.unit-toggle__option'));

    for (const option of options) {
      option.addEventListener('click', () => {
        const target = option.dataset.unitsTarget;
        if (!target) return;
        list.dataset.units = target;
        for (const other of options) {
          const active = other === option;
          other.classList.toggle('is-active', active);
          other.setAttribute('aria-pressed', String(active));
        }
      });
    }
  }

  // Tryb prowadzenia przez przepis: przełącznik zwija etapy Wcześniej/Przygotowanie
  // do samej listy kroków. Bez JS pozostaje ukryty, a strona pokazuje pełną treść.
  const article = document.querySelector<HTMLElement>('.recipe-article');
  const assistantToggle = document.querySelector<HTMLElement>('.assistant-toggle');

  if (article && assistantToggle) {
    assistantToggle.hidden = false;
    const viewOptions = Array.from(
      assistantToggle.querySelectorAll<HTMLButtonElement>('.assistant-toggle__option'),
    );

    for (const option of viewOptions) {
      option.addEventListener('click', () => {
        const target = option.dataset.viewTarget;
        if (!target) return;
        article.dataset.view = target;
        for (const other of viewOptions) {
          const active = other === option;
          other.classList.toggle('is-active', active);
          other.setAttribute('aria-pressed', String(active));
        }
      });
    }
  }

  // Kalkulator startu: po podaniu pory podania liczy godzinę rozpoczęcia każdego
  // etapu z wyprzedzeniem. Bez JS pole i wyliczenia pozostają ukryte, a lista
  // etapów sama w sobie pokazuje potrzebne wyprzedzenie („na 2 godz przed…”).
  const calc = document.querySelector<HTMLElement>('.advance-calc');
  const serveInput = document.querySelector<HTMLInputElement>('#serve-time');
  const startSlots = Array.from(document.querySelectorAll<HTMLElement>('.advance-step__start'));
  const startPreviousDayTemplate = article?.dataset.startPreviousDay;
  const startSameDayTemplate = article?.dataset.startSameDay;

  if (
    calc
    && serveInput
    && startSlots.length > 0
    && startPreviousDayTemplate
    && startSameDayTemplate
  ) {
    calc.hidden = false;

    const render = () => {
      const serveMinutes = parseClock(serveInput.value);

      for (const slot of startSlots) {
        const leadMinutes = Number(slot.dataset.leadMinutes);

        if (serveMinutes === null || !Number.isFinite(leadMinutes)) {
          slot.hidden = true;
          slot.textContent = '';
          continue;
        }

        const [scheduled] = scheduleAdvanceSteps([{ text: '', leadTimeMinutes: leadMinutes }], serveMinutes);
        const clock = formatClock(scheduled.startMinutes);
        const template = scheduled.dayOffset < 0
          ? startPreviousDayTemplate
          : startSameDayTemplate;
        slot.textContent = template.replace('{time}', clock);
        slot.hidden = false;
      }
    };

    serveInput.addEventListener('input', render);
    render();
  }
</script>
