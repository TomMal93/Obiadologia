---
import SiteHeader from '@/components/SiteHeader.astro';
import { defaultLocale } from '@/i18n/config';
import { getMessages } from '@/i18n/messages';
import BaseLayout from '@/layouts/BaseLayout.astro';
import './categories-page.css';

const messages = getMessages(defaultLocale);
---

<BaseLayout
  title={messages.categoriesPlaceholder.meta.title}
  description={messages.categoriesPlaceholder.meta.description}
  locale={defaultLocale}
>
  <SiteHeader messages={messages.common} />

  <main class="categories-placeholder">
    <section class="categories-placeholder-card" aria-labelledby="categories-placeholder-heading">
      <p class="eyebrow">{messages.categoriesPlaceholder.eyebrow}</p>
      <h1 id="categories-placeholder-heading">{messages.categoriesPlaceholder.heading}</h1>
      <p>{messages.categoriesPlaceholder.description}</p>
      <a class="categories-placeholder-back" href="/#kategorie">{messages.categoriesPlaceholder.back}</a>
    </section>
  </main>
</BaseLayout>
