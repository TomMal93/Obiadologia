      border-right: 0;
      border-radius: 0 0 0 14px;
    }

    .decision-start::after {
      inset: auto 0 0 auto;
      border-right-style: solid;
      border-bottom-style: solid;
      border-top: 0;
      border-left: 0;
      border-radius: 0 0 14px 0;
    }

    .decision-start-frame {
      display: none;
    }

    .decision-start-frame::before,
    .decision-start-frame::after {
      content: "";
      position: absolute;
      bottom: 0;
      width: 22px;
      height: 22px;
      border-color: rgba(255, 90, 61, 0.62);
      border-width: 2px;
      pointer-events: none;
    }

    .decision-start-frame::before {
      left: 0;
      border-bottom-style: solid;
      border-left-style: solid;
      border-top: 0;
      border-right: 0;
      border-radius: 0 0 0 14px;
    }

    .decision-start-frame::after {
      right: 0;
      border-right-style: solid;
      border-bottom-style: solid;
      border-top: 0;
      border-left: 0;
      border-radius: 0 0 14px 0;
    }

    .decision-start > span:not(.decision-start-frame) {
      margin: 0 auto;
      max-width: 280px;
      color: rgba(37, 26, 20, 0.76);
      font-size: 17px;
      font-weight: 950;
      line-height: 1.08;
      text-align: center;
      text-wrap: balance;
      transform: none;
    }

    .decision-start > span.decision-start-helper {
      margin-top: 5px;
      color: rgba(37, 26, 20, 0.58);
      font-size: 15px;
      font-weight: 650;
      line-height: 1.12;
    }

    .decision-start-guides {
      position: relative;
      z-index: 1;
      display: block;
      width: min(100%, 408px);
      height: 36px;
      margin: -10px auto -24px;
      pointer-events: none;
    }

    .decision-start-guides-svg {
      display: block;
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .decision-start-guide {
      fill: none;
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-linejoin: round;
      opacity: 0.62;
    }

    .decision-start-guide--map {
      stroke: rgba(32, 137, 230, 0.82);
    }

    .decision-start-guide--craving {
      stroke: rgba(255, 90, 61, 0.78);
    }

    .decision-start-guide--speed {
      stroke: rgba(37, 176, 98, 0.82);
    }

    .decision-start .home-subtitle-rotator {
      width: 100%;
      max-width: 408px;
      margin: -14px auto 0;
      padding: 0;
      display: grid;
      grid-template-rows: 142px 76px 51px;
      gap: 16px;
      align-items: stretch;
      white-space: normal;
    }

    .decision-cues {
      position: relative;
      z-index: 1;
      width: 100%;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 6px;
      font-size: 9.5px;
      font-weight: 850;
      line-height: 1.12;
      text-align: center;
      transform: translateY(3px);
    }

    .decision-cue {
      --cue-rgb: 32, 137, 230;
      --cue-line: rgba(18, 104, 190, 0.28);
      --cue-edge: 26%;
      position: relative;
      min-height: 0;
      padding: 14px 5px 31px;
      display: grid;
      grid-template-rows: repeat(3, 1fr);
      align-items: center;
      justify-items: center;
      gap: 2px;
      color: rgba(37, 26, 20, 0.58);
      text-wrap: balance;
    }

    .decision-cue::before,
    .decision-cue::after {
      content: "";
      position: absolute;
      z-index: -1;
      pointer-events: none;
    }

    .decision-cue::before {
      inset: 4px 1px 24px;
      clip-path: polygon(0 0, 100% 0, calc(100% - var(--cue-edge)) 100%, var(--cue-edge) 100%);
      background:
        radial-gradient(80% 28% at 50% 5%, rgba(255, 255, 255, 0.62), transparent 72%),
        linear-gradient(90deg, rgba(255, 255, 255, 0.18), transparent 24%, transparent 76%, rgba(37, 26, 20, 0.055)),
        linear-gradient(180deg, rgba(var(--cue-rgb), 0.19), rgba(var(--cue-rgb), 0.075) 66%, rgba(var(--cue-rgb), 0.028)),
        rgba(255, 255, 255, 0.08);
      filter: drop-shadow(0 8px 10px rgba(var(--cue-rgb), 0.08));
      opacity: 0.98;
    }

    .decision-cue::after {
      inset: 8px 8px 31px;
      clip-path: polygon(0 0, 100% 0, calc(100% - var(--cue-edge)) 100%, var(--cue-edge) 100%);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.34), transparent 42%),
        linear-gradient(90deg, rgba(var(--cue-rgb), 0.2) 0 1px, transparent 1px calc(100% - 1px), rgba(var(--cue-rgb), 0.2) calc(100% - 1px));
      opacity: 0.52;
    }

    .decision-cue--pantry,
    .decision-cue--craving,
    .decision-cue--speed {
      font-size: 12px;
      font-weight: 650;
    }

    .decision-cue--craving {
      --cue-rgb: 255, 90, 61;
      --cue-line: rgba(214, 62, 37, 0.32);
      grid-template-rows: repeat(4, 1fr);
    }

    .decision-cue--speed {
      --cue-rgb: 37, 176, 98;
      --cue-line: rgba(20, 132, 72, 0.28);
      grid-template-rows: repeat(4, 1fr);
    }

    .decision-cue > span:not(.decision-cue-arrow) {
      display: block;
      position: relative;
      z-index: 1;
    }

    .decision-cue > span:not(.decision-cue-arrow):nth-child(1) {
      transform: translate(-5px, 2px) rotate(-5deg);
    }

    .decision-cue > span:not(.decision-cue-arrow):nth-child(2) {
      transform: translate(6px, -1px) rotate(4deg);
    }

    .decision-cue > span:not(.decision-cue-arrow):nth-child(3) {
      transform: translate(-2px, 1px) rotate(-3deg);
    }

    .decision-cue--craving > span:not(.decision-cue-arrow):nth-child(1) {
      transform: translate(-3px, 1px) rotate(4deg);
    }

    .decision-cue--craving > span:not(.decision-cue-arrow):nth-child(2) {
      transform: translate(-5px, 4px) rotate(-4deg);
    }

    .decision-cue--craving > span:not(.decision-cue-arrow):nth-child(3) {
      transform: translate(10px, 7px) rotate(-3deg);
    }

    .decision-cue--craving > span:not(.decision-cue-arrow):nth-child(4) {
      transform: translate(-10px, -4px) rotate(7deg);
    }

    .decision-cue--speed > span:not(.decision-cue-arrow):nth-child(1) {
      transform: translate(-6px, 2px) rotate(-5deg);
    }

    .decision-cue--speed > span:not(.decision-cue-arrow):nth-child(2) {
      transform: translate(6px, -2px) rotate(5deg);
    }

    .decision-cue--speed > span:not(.decision-cue-arrow):nth-child(3) {
      transform: translate(-3px, 1px) rotate(3deg);
    }

    .decision-cue--speed > span:not(.decision-cue-arrow):nth-child(4) {
      transform: translate(4px, -2px) rotate(-4deg);
    }

    .decision-cue-arrow {
      position: absolute;
      left: 50%;
      bottom: -6px;
      width: 20px;
      height: 24px;
      transform: translateX(-50%);
    }

    .decision-cue-arrow::before {
      content: "";
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      background: var(--cue-line);
    }

    .decision-cue-arrow::before {
      top: 0;
      width: 2px;
      height: 13px;
      border-radius: 999px;
    }

    .decision-cue-arrow::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 2px;
      width: 14px;
      height: 18px;
      background: var(--cue-line);
      clip-path: polygon(0 0, 50% 56%, 100% 0, 100% 18%, 50% 100%, 0 18%);
      transform: translateX(-50%);
    }

    .decision-start .decision-option-list {
      position: relative;
      z-index: 2;
      width: 100%;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 7px;
    }

    .decision-start .decision-option {
      min-height: 76px;
      padding: 10px 6px 12px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      text-align: center;
      box-shadow:
        0 18px 30px rgba(37, 26, 20, 0.17),
        0 6px 12px rgba(37, 26, 20, 0.12),
        0 2px 0 var(--option-lift),
        inset 0 1px 0 var(--option-top),
        inset 0 0 0 1px var(--option-glass-edge),
        inset 0 -14px 20px var(--option-depth);
      backdrop-filter: blur(24px) saturate(1.48) contrast(1.06);
      -webkit-backdrop-filter: blur(24px) saturate(1.48) contrast(1.06);
    }

    .decision-start .decision-option::after {
      display: none;
    }

    .decision-start .decision-option span {
      color: var(--option-text);
      font-size: 16px;
      font-weight: 980;
      line-height: 1;
      text-shadow:
        0 1px 0 var(--option-text-shadow),
        0 10px 18px rgba(37, 26, 20, 0.16);
    }

    .decision-start .home-subtitle-rotator-copy {
      width: 100%;
      min-width: 0;
      margin: 0;
      padding: 11px 14px;
      display: grid;
      grid-template-columns: max-content 6.8ch;
      justify-content: center;
      align-items: center;
      gap: 0;
      border: 1px solid rgba(126, 101, 72, 0.18);
      border-radius: 12px;
      background:
        radial-gradient(110% 120% at 18% 0%, rgba(255, 248, 229, 0.42), transparent 58%),
        linear-gradient(155deg, rgba(255, 253, 248, 0.34), rgba(231, 219, 195, 0.16)),
        rgba(255, 253, 248, 0.18);
      box-shadow:
        0 12px 24px rgba(37, 26, 20, 0.075),
        0 2px 6px rgba(37, 26, 20, 0.045),
        inset 0 1px 0 rgba(255, 255, 255, 0.58),
        inset 0 0 0 1px rgba(255, 255, 255, 0.22),
        inset 0 -8px 18px rgba(126, 101, 72, 0.055);
      backdrop-filter: blur(22px) saturate(1.18);
      -webkit-backdrop-filter: blur(22px) saturate(1.18);
      white-space: nowrap;
    }

    .decision-start .home-subtitle-label {
      justify-self: end;
      color: rgba(37, 26, 20, 0.7);
      font-size: 15px;
      font-weight: 780;
      line-height: 1.1;
      text-align: right;
    }

    .decision-start .home-subtitle-mode {
      justify-self: start;
      width: 6.8ch;
      font-size: 15px;
      font-weight: 900;
      line-height: 1.1;
      text-align: left;
    }

    .decision-start .home-subtitle-mode > span {
      text-align: left;
    }
  }

  @media (max-width: 430px) and (max-height: 740px) {
    .home-subtitle {
      margin-top: 32px;
      padding: 14px 12px 12px;
      gap: 11px;
    }

    .home-subtitle-card {
      padding-bottom: 12px;
      gap: 4px;
    }

    .home-subtitle-card .decision-preview {
      gap: 4px;
    }

    .decision-start {
      gap: 8px;
    }

    .decision-start > span:not(.decision-start-frame) {
      font-size: 16px;
    }

    .decision-start > span.decision-start-helper {
      margin-top: 2px;
      font-size: 14px;
    }

    .home-subtitle-card .home-subtitle-main,
    .home-subtitle-card .decision-preview-copy p {
      font-size: 14px;
    }

    .decision-start-guides {
      height: 28px;
      margin: -7px auto -18px;
    }

    .decision-start .home-subtitle-rotator {
      grid-template-rows: 116px 70px 45px;
      gap: 10px;
      margin-top: -8px;
    }

    .decision-cue {
      padding: 11px 3px 25px;
    }

    .decision-cue--pantry,
    .decision-cue--craving,
    .decision-cue--speed {
      font-size: 11px;
    }

    .decision-start .decision-option {
      min-height: 70px;
    }

    .decision-start .home-subtitle-rotator-copy {
      padding-block: 9px;
    }
  }

  .decision-surface--desktop {
    display: none;
    margin-top: 28px;
  }

  .decision-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    height: 100dvh;
    overflow-y: auto;
    padding: 14px 18px 34px;
    background: var(--bg);
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    transform-origin: top center;
    transition:
      transform 300ms ease-out,
      opacity 300ms ease-out;
  }

  .decision-overlay.is-open {
    opacity: 1;
    transform: translateY(0);
  }

  .decision-overlay.is-closing {
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    transition:
      transform 250ms ease-in,
      opacity 250ms ease-in;
  }

  .overlay-header {
    min-height: 56px;
    display: grid;
    grid-template-columns: 44px 1fr 44px;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .overlay-close {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.86);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 29px;
    line-height: 1;
  }

  .overlay-brand {
    justify-self: center;
    font-size: 18px;
    font-weight: 950;
    letter-spacing: -0.04em;
  }

  .mode {
    padding: 0;
  }

  .decision-surface--desktop .mode {
    margin-top: 0;
    padding: 14px;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  .mode input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .switch {
    width: 100%;
    max-width: 390px;
    margin: 0 auto;
    padding: 7px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 248, 239, 0.7);
  }

  .switch label {
    min-height: 44px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 950;
    transition: 0.2s ease;
    user-select: none;
  }

  #desktopSearchMode:checked ~ .switch label[for="desktopSearchMode"],
  #desktopMapMode:checked ~ .switch label[for="desktopMapMode"],
  #mobileSearchMode:checked ~ .switch label[for="mobileSearchMode"],
  #mobileMapMode:checked ~ .switch label[for="mobileMapMode"] {
    background: var(--text);
    color: white;
    box-shadow: 0 8px 18px rgba(37, 26, 20, 0.12);
  }

  .panels { margin-top: 14px; }
  .decision-surface--desktop .panels { margin-top: 0; }
  .panel { display: none; }
  #desktopSearchMode:checked ~ .panels .search-panel,
  #desktopMapMode:checked ~ .panels .map-panel,
  #mobileSearchMode:checked ~ .panels .search-panel,
  #mobileMapMode:checked ~ .panels .map-panel { display: block; }

  .decision-surface--desktop .panels + .switch {
    margin-top: 14px;
  }

  .search-card,
  .map-card {
    min-height: 220px;
    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .search-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
  }

  .search-card-header,
  .map-card-header {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    gap: 12px;
    align-items: flex-start;
    text-align: center;
  }

  .search-card h2,
  .map-card h2 {
    margin: 0 auto;
    max-width: none;
    white-space: nowrap;
    font-size: clamp(17px, 4.9vw, 19px);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .search-card p,
  .map-card p {
    margin: 7px auto 0;
    max-width: none;
    color: var(--muted);
    white-space: nowrap;
    font-size: clamp(11px, 3.35vw, 13px);
    line-height: 1.35;
  }

  .search-box {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 8px;
    border-radius: 22px;
    background: #fff8ef;
    border: 1px solid rgba(37, 26, 20, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.65);
  }

  .input-wrap input {
    width: 100%;
    min-height: 56px;
    border: 0;
    outline: none;
    padding: 15px 16px;
    border-radius: 17px;
    background: transparent;
    color: var(--text);
    font-size: 16px;
    font-weight: 650;
  }

  .input-wrap input::placeholder {
    color: rgba(122, 102, 88, 0.82);
    font-weight: 600;
  }

  .search-box button {
    min-height: 48px;
    padding: 0 18px;
    border-radius: 16px;
    background: var(--accent);
    color: white;
    font-weight: 950;
    box-shadow: 0 14px 30px rgba(255, 90, 61, 0.26);
  }

  .search-card .chips {
    display: flex;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding: 0 0 2px;
    scrollbar-width: none;
  }

  .search-card .chips::-webkit-scrollbar { display: none; }

  button.chip {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    background: #fffdf8;
    font-size: 12px;
    font-weight: 850;
  }

  .map-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: visible;
    text-align: center;
  }

  .open-map {
    width: fit-content;
    margin: 0 auto;
    flex: 0 0 auto;
    min-height: 38px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    padding: 0 13px;
    background: var(--text);
    color: white;
    font-size: 12px;
    font-weight: 950;
  }

  .taste-map {
    position: relative;
    width: 100%;
    height: auto;
    aspect-ratio: 2.35 / 1;
    border-radius: 20px;
    background:
      linear-gradient(to right, transparent 49.5%, rgba(37, 26, 20, 0.16) 49.5% 50.5%, transparent 50.5%),
      linear-gradient(to bottom, transparent 49.5%, rgba(37, 26, 20, 0.16) 49.5% 50.5%, transparent 50.5%),
      #fff8ef;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .axis {
    position: absolute;
    font-size: 8px;
    font-weight: 950;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    user-select: none;
  }

  .axis.fast { left: 7px; top: 50%; transform: translateY(-50%); }
  .axis.slow { right: 7px; top: 50%; transform: translateY(-50%); }
  .axis.light { top: 7px; left: 50%; transform: translateX(-50%); }
  .axis.heavy { bottom: 7px; left: 50%; transform: translateX(-50%); }

  .dot {
    position: absolute;
    width: 18px;
    height: 18px;
    padding: 0;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 8px 18px rgba(255, 90, 61, 0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    animation: dotFloat 2.8s ease-in-out infinite alternate;
  }

  .dot span { display: none; }
  .dot.one { left: 25%; top: 28%; }
  .dot.two { left: 23%; bottom: 26%; background: var(--green); animation-delay: -0.6s; }
  .dot.three { right: 26%; top: 32%; background: var(--accent-2); animation-delay: -1.1s; }
  .dot.four { right: 22%; bottom: 24%; animation-delay: -1.7s; }
  .dot.active { transform: scale(1.24); box-shadow: 0 0 0 7px rgba(255, 90, 61, 0.12); }

  .map-tags {
    position: static;
    display: flex;
    justify-content: center;
    gap: 7px;
    flex-wrap: wrap;
    max-width: none;
  }

  .map-tag {
    padding: 7px 9px;
    font-size: 11px;
  }

  .results {
    margin-top: 24px;
    text-align: left;
    scroll-margin-top: 16px;
  }

  .results-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
    padding-inline: 4px;
  }

  .results-header h2 {
    margin: 0;
    font-size: 28px;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .results-header span {
    color: var(--muted);
    font-size: 13px;
    font-weight: 850;
    white-space: nowrap;
  }

  .carousel-wrap {
    position: relative;
  }

  .carousel-viewport {
    height: calc(3 * 142px + 2 * 12px);
    overflow-y: auto;
    overflow-x: hidden;
    scroll-behavior: smooth;
    scrollbar-width: none;
    border-radius: 24px;
  }

  .carousel-viewport::-webkit-scrollbar { display: none; }

  .result-list {
    display: grid;
    gap: 12px;
  }

  .empty-state {
    margin: 12px 0 0;
    padding: 14px;
    border-radius: 18px;
    background: rgba(255, 253, 248, 0.88);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 13px;
    font-weight: 850;
    text-align: center;
  }

  .suggestions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .suggestion-chip {
    min-height: 34px;
    padding: 0 11px;
    border-radius: 999px;
    background: var(--text);
    color: white;
    font-size: 12px;
    font-weight: 950;
  }

  .carousel-arrow {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) scale(0.85);
    z-index: 5;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.92);
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(37, 26, 20, 0.12);
    backdrop-filter: blur(10px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.2s ease;
  }

  .carousel-arrow.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) scale(1);
  }

  .carousel-arrow:active {
    transform: translateX(-50%) scale(0.9);
  }

  .carousel-arrow--up {
    top: -20px;
  }

  .carousel-arrow--down {
