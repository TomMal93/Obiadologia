import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import RecipeCard from "@components/RecipeCard.astro";

const recipes = (await getCollection("recipes")).sort((a, b) => a.data.timeMinutes - b.data.timeMinutes);
const searchDocuments = recipes.map(({ id, data }) => ({
  id,
  title: data.title,
  summary: data.summary,
  description: data.description,
  timeMinutes: data.timeMinutes,
  tags: data.tags,
  categories: data.categories,
  mainIngredients: data.mainIngredients,
  searchAliases: data.searchAliases,
  effort: data.effort,
  mood: data.mood,
  cost: data.cost,
  equipment: data.equipment ?? [],
  diet: data.diet ?? []
}));

function getRecipeCountLabel(count: number) {
  if (count === 1) return "1 przepis";
  if (count > 1 && count < 5) return `${count} przepisy`;
  return `${count} przepisów`;
}

type CategoryTile = {
  title: string;
  label: string;
  icon: string;
  tone: string;
  filter: { type: "all" } | { type: "tag" | "query"; value: string };
};

function getCategoryCount(category: CategoryTile) {
  if (category.filter.type === "all") return recipes.length;

  const value = category.filter.value.toLowerCase();
  return recipes.filter((recipe) => {
    const searchable = [
      recipe.data.title,
      recipe.data.summary,
      recipe.data.description,
      recipe.data.effort,
      recipe.data.mood,
      recipe.data.cost,
      ...recipe.data.tags,
      ...recipe.data.mainIngredients,
      ...recipe.data.searchAliases
    ].join(" ").toLowerCase();

    if (category.filter.type === "tag") return recipe.data.tags.includes(category.filter.value);
    return searchable.includes(value);
  }).length;
}

function getCategoryHref(category: CategoryTile) {
  if (category.filter.type === "all") return "/przepisy";

  const param = category.filter.type === "tag" ? "tag" : "q";
  return `/przepisy?${param}=${encodeURIComponent(category.filter.value)}`;
}

const categoryIconPaths: Record<string, string> = {
  all: '<rect x="4" y="4" width="6" height="6" rx="1.5" /><rect x="14" y="4" width="6" height="6" rx="1.5" /><rect x="4" y="14" width="6" height="6" rx="1.5" /><rect x="14" y="14" width="6" height="6" rx="1.5" />',
  "30": '<circle cx="12" cy="12" r="8" /><path d="M12 7v5l3 2" />',
  "15": '<circle cx="12" cy="12" r="8" /><path d="M12 8v4" /><path d="M9.5 14.5h5" />',
  "zł": '<circle cx="12" cy="12" r="8" /><path d="M9 9h6l-6 6h6" /><path d="M15 7l-6 10" />',
  "1": '<path d="M7 9h10" /><path d="M8 9l1 9h6l1-9" /><path d="M10 6c.8-1.2 3.2-1.2 4 0" />',
  dom: '<path d="M4 11.5 12 5l8 6.5" /><path d="M7 10.5V19h10v-8.5" /><path d="M10 19v-5h4v5" />',
  mix: '<path d="M7 7h3a4 4 0 0 1 4 4v5" /><path d="m11 13 3 3 3-3" /><path d="M17 7h-2.5A4.5 4.5 0 0 0 10 11.5V17" /><path d="m13 14-3 3-3-3" />',
  egg: '<path d="M17 14c0 4-2.4 6-5 6s-5-2-5-6c0-3.3 2.1-9 5-9s5 5.7 5 9Z" />',
  chleb: '<path d="M5 11c0-3 2.5-5 7-5s7 2 7 5v7H5z" /><path d="M8 11h.01" /><path d="M12 10h.01" /><path d="M16 11h.01" />',
  ser: '<path d="m5 11 8-5 6 5v7H5z" /><path d="M9 14h.01" /><path d="M14 12h.01" /><path d="M16 16h.01" />',
  gar: '<path d="M6 10h12" /><path d="M8 10v7a3 3 0 0 0 3 3h2a3 3 0 0 0 3-3v-7" /><path d="M9 7h6" /><path d="M4 13h2" /><path d="M18 13h2" />',
  wege: '<path d="M19 5c-7 0-12 4-12 10 0 2.2 1.8 4 4 4 6 0 8-7 8-14Z" /><path d="M7 19c2.5-5 6-8 10-10" />',
  "ryż": '<path d="M5 11h14l-1.2 5.8A4 4 0 0 1 13.9 20h-3.8a4 4 0 0 1-3.9-3.2z" /><path d="M8 8c1-1 2-1 3 0" /><path d="M13 8c1-1 2-1 3 0" />',
  "2": '<rect x="5" y="6" width="14" height="12" rx="2" /><path d="M5 11h14" /><path d="M12 6v12" />',
  share: '<circle cx="8" cy="12" r="2.5" /><circle cx="16" cy="7" r="2.5" /><circle cx="16" cy="17" r="2.5" /><path d="m10.2 10.8 3.6-2.4" /><path d="m10.2 13.2 3.6 2.4" />'
};

function getCategoryIcon(icon: string) {
  const path = categoryIconPaths[icon] ?? categoryIconPaths.all;
  return `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="#9a4a35" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}

const categoryModes = [
  {
    id: "daily",
    title: "Codziennie",
    helper: "Najprostsze wejścia, kiedy po prostu trzeba coś zjeść.",
    tiles: [
      { title: "Wszystkie", label: "pełna lista pomysłów", filter: { type: "all" }, icon: "all", tone: "fire" },
      { title: "Szybkie", label: "bez długiego stania", filter: { type: "tag", value: "do 30 minut" }, icon: "30", tone: "blue" },
      { title: "Tanie", label: "bez dużych zakupów", filter: { type: "tag", value: "tanie" }, icon: "zł", tone: "sun" },
      { title: "Mało zmywania", label: "mniej garów po wszystkim", filter: { type: "tag", value: "mało zmywania" }, icon: "1", tone: "leaf" },
      { title: "Bez zakupów", label: "z tego, co już masz", filter: { type: "tag", value: "bez zakupów" }, icon: "dom", tone: "green" },
      { title: "Z resztek", label: "drugie życie lodówki", filter: { type: "tag", value: "z resztek" }, icon: "mix", tone: "tomato" }
    ]
  },
  {
    id: "breakfast",
    title: "Śniadanie",
    helper: "Rzeczy na mniejszy głód, jajka, pieczywo i szybkie patelnie.",
    tiles: [
      { title: "Jajka", label: "na ciepło albo z patelni", filter: { type: "query", value: "jajka" }, icon: "egg", tone: "sun" },
      { title: "Pieczywo", label: "gdy trzeba zużyć chleb", filter: { type: "query", value: "pieczywo" }, icon: "chleb", tone: "tomato" },
      { title: "Serowe", label: "tosty, tortilla, dodatki", filter: { type: "query", value: "ser" }, icon: "ser", tone: "blue" },
      { title: "Do 15 minut", label: "szybki start dnia", filter: { type: "tag", value: "do 15 minut" }, icon: "15", tone: "fire" }
    ]
  },
  {
    id: "dinner",
    title: "Obiad",
    helper: "Konkretniej, cieplej, bardziej sycąco.",
    tiles: [
      { title: "Jednogarnkowe", label: "wszystko w jednym", filter: { type: "tag", value: "jednogarnkowe" }, icon: "gar", tone: "blue" },
      { title: "Bez mięsa", label: "warzywa grają pierwsze", filter: { type: "tag", value: "bez mięsa" }, icon: "wege", tone: "green" },
      { title: "Ryż", label: "miska, curry albo patelnia", filter: { type: "query", value: "ryż" }, icon: "ryż", tone: "leaf" },
      { title: "Na dwa dni", label: "obiad plus lunch", filter: { type: "tag", value: "na dwa dni" }, icon: "2", tone: "tomato" }
    ]
  },
  {
    id: "party",
    title: "Impreza",
    helper: "Proste rzeczy do postawienia na stole albo zrobienia hurtowo.",
    tiles: [
      { title: "Do podziału", label: "wrapy, patelnie, miski", filter: { type: "query", value: "tortilla" }, icon: "share", tone: "fire" },
      { title: "Tanie", label: "więcej porcji bez dramatu", filter: { type: "tag", value: "tanie" }, icon: "zł", tone: "sun" },
      { title: "Bez mięsa", label: "dla różnych gości", filter: { type: "tag", value: "bez mięsa" }, icon: "wege", tone: "green" },
      { title: "Mało zmywania", label: "łatwiejszy koniec wieczoru", filter: { type: "tag", value: "mało zmywania" }, icon: "1", tone: "leaf" }
    ]
  },
  {
    id: "tomorrow",
    title: "Na jutro",
    helper: "Dania, które nie obrażają się na pudełko i odgrzewanie.",
    tiles: [
      { title: "Na dwa dni", label: "dzisiaj i do pracy", filter: { type: "tag", value: "na dwa dni" }, icon: "2", tone: "tomato" },
      { title: "Ryż", label: "dobry do pudełka", filter: { type: "query", value: "ryż" }, icon: "ryż", tone: "blue" },
      { title: "Jednogarnkowe", label: "mniej pilnowania", filter: { type: "tag", value: "jednogarnkowe" }, icon: "gar", tone: "green" },
      { title: "Z resztek", label: "drugie życie lodówki", filter: { type: "tag", value: "z resztek" }, icon: "mix", tone: "sun" }
    ]
  }
].map((mode) => ({
  ...mode,
  tiles: mode.tiles.map((category) => {
    const count = getCategoryCount(category);
    return {
      ...category,
      href: getCategoryHref(category),
      count,
      countLabel: getRecipeCountLabel(count)
    };
  })
}));

---

<BaseLayout
  title="Obiadologia - Decyzyjnik obiadowy"
  description="Mobile-first decyzyjnik obiadowy. Wpisz składniki albo wybierz nastrój i szybciej zdecyduj, co dziś ugotować."
  mainClass="home-screen-stack"
>
  <section class="hero home-decision screen-section">
    <div class="home-hero-copy">
      <h1 class="home-title">Co dziś <span>jemy?</span></h1>
    </div>

    <div class="home-subtitle" data-decision-launcher aria-label="Szybki wybór obiadu">
      <div class="home-subtitle-card">
        <span class="home-subtitle-main">
          <span style="display: block;">Odwieczny problem z tym, co ugotować, nie musi już psuć Ci apetytu.</span>
        </span>

        <div class="decision-preview">
          <svg class="home-subtitle-separator" viewBox="0 0 260 28" preserveAspectRatio="none" aria-hidden="true" focusable="false">
            <path d="M6 15 C48 2 84 26 126 14 C166 2 198 26 254 13" />
          </svg>

          <div class="decision-preview-copy">
            <p>Zdejmujemy z Ciebie ciężar decyzji, wyznaczając najkrótszą drogę od burczenia w brzuchu do pełnego talerza.</p>
          </div>
        </div>

      </div>

      <div class="decision-start" aria-label="Sposoby rozpoczęcia wyboru obiadu">
        <span class="decision-start-frame" aria-hidden="true"></span>
        <span>Wybierz najbliższą myśl:</span>
        <span class="decision-start-helper">Do obiadu prowadzi mnie:</span>
        <span class="decision-start-guides" aria-hidden="true">
          <svg class="decision-start-guides-svg" viewBox="0 0 408 46" preserveAspectRatio="none" focusable="false">
            <path class="decision-start-guide decision-start-guide--map" d="M176 2 C124 8 83 17 56 43" />
            <path class="decision-start-guide decision-start-guide--craving" d="M204 1 C198 13 212 24 204 44" />
            <path class="decision-start-guide decision-start-guide--speed" d="M232 2 C284 7 326 18 352 43" />
          </svg>
        </span>
        <div class="home-subtitle-rotator">
          <div class="decision-cues" aria-hidden="true">
            <span class="decision-cue decision-cue--pantry">
              <span>Poszukiwania</span>
              <span>inspiracja</span>
              <span>nastrój</span>
              <span class="decision-cue-arrow"></span>
            </span>
            <span class="decision-cue decision-cue--craving">
              <span>konkretne danie</span>
              <span>składnik</span>
              <span>ochota</span>
              <span>smak</span>
              <span class="decision-cue-arrow"></span>
            </span>
            <span class="decision-cue decision-cue--speed">
              <span>okazja</span>
              <span>sytuacja</span>
              <span>wena</span>
              <span>tempo</span>
              <span class="decision-cue-arrow"></span>
            </span>
          </div>
          <div class="decision-option-list">
            <button class="decision-option" type="button" data-open-decision="map">
              <span>Mapa</span>
            </button>
            <button class="decision-option" type="button" data-open-decision="search">
              <span>Szukaj</span>
            </button>
            <button class="decision-option" type="button" data-scroll-to-categories>
              <span>Kategorie</span>
            </button>
          </div>

          <span class="home-subtitle-rotator-copy">
            <span class="home-subtitle-label">Od razu dostajesz:</span>
            <span class="home-subtitle-mode" data-home-subtitle-mode>
              <span data-home-subtitle-current>konkret</span>
              <span data-home-subtitle-next aria-hidden="true"></span>
            </span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <section class="decision-surface decision-surface--desktop screen-section" data-decision-surface="desktop">
    <div class="mode">
      <input type="radio" name="desktopMode" id="desktopSearchMode" checked data-search-mode />
      <input type="radio" name="desktopMode" id="desktopMapMode" data-map-mode />

      <div class="panels">
        <div class="panel search-panel">
          <div class="search-card">
            <div class="search-card-header">
              <div>
                <h2>Masz trop? Wpisz go tutaj</h2>
                <p>Składnik, smak czy nazwa dania, wszystko działa.</p>
              </div>
            </div>

            <form class="search-box" data-home-search>
              <div class="input-wrap">
                <label class="sr-only" for="desktop-home-query">Składniki</label>
                <input id="desktop-home-query" data-home-query type="search" placeholder="ryż, tanie, mało zmywania, curry..." autocomplete="off" />
              </div>

              <button type="submit">Szukaj</button>
            </form>

            <div class="chips" aria-label="Szybkie podpowiedzi">
              <button class="chip" type="button" data-home-chip="makaron">mam makaron</button>
              <button class="chip" type="button" data-home-chip="kurczak">coś z kurczakiem</button>
              <button class="chip" type="button" data-home-chip="bez mięsa">bez mięsa</button>
              <button class="chip" type="button" data-home-chip="mało zmywania">mało zmywania</button>
            </div>
          </div>
        </div>

        <div class="panel map-panel">
          <div class="map-card">
            <div class="map-card-header">
              <div>
                <h2>Wskaż klimat na mapie</h2>
                <p>Szybko, lekko czy konkretnie, mapa podpowie.</p>
              </div>
            </div>

            <div class="map-tags" data-map-tags>
              <span class="map-tag">szybko</span>
              <span class="map-tag">konkretnie</span>
              <span class="map-tag">mało garów</span>
            </div>

            <div class="taste-map" aria-label="Mapa smaków">
              <span class="axis fast">szybko</span>
              <span class="axis slow">wolno</span>
              <span class="axis light">lekko</span>
              <span class="axis heavy">konkretnie</span>

              <button class="dot one" type="button" data-map-filter="do 15 minut" aria-label="Szybko i lekko"><span>szybko</span></button>
              <button class="dot two" type="button" data-map-filter="mało zmywania" aria-label="Szybko i konkretnie"><span>patelnia</span></button>
              <button class="dot three" type="button" data-map-filter="bez mięsa" aria-label="Wolniej i lekko"><span>curry</span></button>
              <button class="dot four" type="button" data-map-filter="na dwa dni" aria-label="Wolniej i konkretnie"><span>garnek</span></button>
            </div>

            <a class="open-map" href="/przepisy">Otwórz</a>
          </div>
        </div>
      </div>

      <div class="switch" aria-label="Tryb wyboru obiadu">
        <label for="desktopSearchMode">Wyszukiwarka</label>
        <label for="desktopMapMode">Mapa</label>
      </div>
    </div>

    <section class="results" data-results-section aria-live="polite">
      <div class="results-header">
        <h2>Propozycje</h2>
        <span data-home-count>{recipes.length} wyniki</span>
      </div>

      <div class="carousel-wrap" data-carousel-wrap>
        <button class="carousel-arrow carousel-arrow--up" data-carousel-up aria-label="Przewiń w górę" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
        </button>

        <div class="carousel-viewport" data-carousel-viewport>
          <div class="result-list" data-result-list>
            {recipes.map((recipe, index) => (
              <RecipeCard recipe={recipe} index={index} variant="result" homeResult />
            ))}
          </div>
        </div>

        <button class="carousel-arrow carousel-arrow--down" data-carousel-down aria-label="Przewiń w dół" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>

      <p class="empty-state" data-home-empty hidden>Nie znalazłem takiego obiadu, więc pokazuję wszystkie propozycje.</p>
      <div class="suggestions" data-home-suggestions hidden aria-label="Podpowiedzi wyszukiwania"></div>
    </section>
  </section>

  <div class="decision-overlay" data-decision-overlay hidden>
    <section class="decision-surface decision-surface--mobile" data-decision-surface="mobile">
      <div class="overlay-header">
        <button class="overlay-close" type="button" data-close-decision aria-label="Zamknij decyzyjnik">
          <span aria-hidden="true">×</span>
        </button>
        <a class="overlay-brand" href="/">Obiadologia</a>
      </div>

      <div class="mode">
        <input type="radio" name="mobileMode" id="mobileSearchMode" checked data-search-mode />
        <input type="radio" name="mobileMode" id="mobileMapMode" data-map-mode />

        <div class="switch" aria-label="Tryb wyboru obiadu">
          <label for="mobileSearchMode">Wyszukiwarka</label>
          <label for="mobileMapMode">Mapa</label>
        </div>

        <div class="panels">
          <div class="panel search-panel">
            <div class="search-card">
              <div class="search-card-header">
                <div>
                  <h2>Masz trop? Wpisz go tutaj</h2>
                  <p>Składnik, smak czy nazwa dania, wszystko działa.</p>
                </div>
              </div>

              <form class="search-box" data-home-search>
                <div class="input-wrap">
                  <label class="sr-only" for="mobile-home-query">Składniki</label>
                  <input id="mobile-home-query" data-home-query type="search" placeholder="ryż, tanie, mało zmywania, curry..." autocomplete="off" />
                </div>

                <button type="submit">Szukaj</button>
              </form>

              <div class="chips" aria-label="Szybkie podpowiedzi">
                <button class="chip" type="button" data-home-chip="makaron">mam makaron</button>
                <button class="chip" type="button" data-home-chip="kurczak">coś z kurczakiem</button>
                <button class="chip" type="button" data-home-chip="bez mięsa">bez mięsa</button>
                <button class="chip" type="button" data-home-chip="mało zmywania">mało zmywania</button>
              </div>
            </div>
          </div>

          <div class="panel map-panel">
            <div class="map-card">
              <div class="map-card-header">
                <div>
                  <h2>Wskaż klimat na mapie</h2>
                  <p>Szybko, lekko czy konkretnie, mapa podpowie.</p>
                </div>
              </div>

              <div class="map-tags" data-map-tags>
                <span class="map-tag">szybko</span>
                <span class="map-tag">konkretnie</span>
                <span class="map-tag">mało garów</span>
              </div>

              <div class="taste-map" aria-label="Mapa smaków">
                <span class="axis fast">szybko</span>
                <span class="axis slow">wolno</span>
                <span class="axis light">lekko</span>
                <span class="axis heavy">konkretnie</span>

                <button class="dot one" type="button" data-map-filter="do 15 minut" aria-label="Szybko i lekko"><span>szybko</span></button>
                <button class="dot two" type="button" data-map-filter="mało zmywania" aria-label="Szybko i konkretnie"><span>patelnia</span></button>
                <button class="dot three" type="button" data-map-filter="bez mięsa" aria-label="Wolniej i lekko"><span>curry</span></button>
                <button class="dot four" type="button" data-map-filter="na dwa dni" aria-label="Wolniej i konkretnie"><span>garnek</span></button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <section class="results" data-results-section aria-live="polite">
        <div class="results-header">
          <h2>Propozycje</h2>
          <span data-home-count>{recipes.length} wyniki</span>
        </div>

        <div class="result-list" data-result-list>
          {recipes.map((recipe, index) => (
            <RecipeCard recipe={recipe} index={index} variant="result" homeResult />
          ))}
        </div>

        <p class="empty-state" data-home-empty hidden>Nie znalazłem takiego obiadu, więc pokazuję wszystkie propozycje.</p>
        <div class="suggestions" data-home-suggestions hidden aria-label="Podpowiedzi wyszukiwania"></div>
      </section>
    </section>
  </div>

  <section class="section screen-section" id="tryby" data-categories-section>
    <div class="section-head">
      <h2>Wybierz tryb</h2>
    </div>

    <div class="category-frame category-frame--modes">
      <p class="category-mode-intro">Zacznij od sytuacji. Każdy tryb podmienia zestaw skrótów poniżej.</p>

      <div class="category-mode-picker" role="tablist" aria-label="Tryby sytuacji">
        {categoryModes.map((mode, index) => (
          <button
            class:list={["category-mode", { "is-active": index === 0 }]}
            type="button"
            role="tab"
            id={`category-mode-${mode.id}`}
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`category-panel-${mode.id}`}
            data-category-mode={mode.id}
            data-category-title={mode.title}
          >
            {mode.title}
          </button>
        ))}
        {[
          { title: "Lunch", mobileSlot: "lunch" },
          { title: "Kolacja", mobileSlot: "dinner" },
          { title: "Plan", mobileSlot: "plan" }
        ].map((mode) => (
          <button
            class:list={[
              "category-mode",
              "category-mode--placeholder",
              `category-mode--placeholder-${mode.mobileSlot}`
            ]}
            type="button"
            disabled
            aria-disabled="true"
          >
            {mode.title}
          </button>
        ))}
      </div>

      <div class="category-mode-summary" aria-live="polite">
        <span>Wybrano</span>
        <strong data-category-mode-title>{categoryModes[0].title}</strong>
      </div>

      <div class="category-mode-action">
        <p>Teraz wybierz konkretny skrót do przepisów.</p>
      </div>

      <div class="category-panels">
        {categoryModes.map((mode, index) => (
          <div
            class:list={["category-panel", { "is-active": index === 0 }]}
            id={`category-panel-${mode.id}`}
            role="tabpanel"
            aria-labelledby={`category-mode-${mode.id}`}
            data-category-panel={mode.id}
            hidden={index !== 0}
          >
            <p class="category-panel-helper">{mode.helper}</p>
            <div class="category-row">
              {mode.tiles.map((category) => (
                <a class:list={["category", `category--${category.tone}`]} href={category.href}>
                  <span class="category-icon" aria-hidden="true" set:html={getCategoryIcon(category.icon)} />
                  <strong>{category.title}</strong>
                  <span class="category-count">{category.countLabel}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/json" data-recipe-search-docs set:html={JSON.stringify(searchDocuments)}></script>

<script>
  import { createRecipeSearch } from "../lib/recipeSearch";

  const recipeDocuments = JSON.parse(document.querySelector("[data-recipe-search-docs]")?.textContent ?? "[]");
  const recipeSearch = createRecipeSearch(recipeDocuments);
  const allIds = recipeSearch.search({ sort: "time" }).ids;
  const overlay = document.querySelector<HTMLElement>("[data-decision-overlay]");
  const decisionLauncher = document.querySelector<HTMLElement>("[data-decision-launcher]");
  const mobileSurface = document.querySelector<HTMLElement>('[data-decision-surface="mobile"]');
  const homeSubtitleMode = document.querySelector<HTMLElement>("[data-home-subtitle-mode]");
  const homeSubtitleCurrent = homeSubtitleMode?.querySelector<HTMLElement>("[data-home-subtitle-current]");
  const homeSubtitleNext = homeSubtitleMode?.querySelector<HTMLElement>("[data-home-subtitle-next]");
  const categoryModeButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-category-mode]")];
  const categoryPanels = [...document.querySelectorAll<HTMLElement>("[data-category-panel]")];
  const categoryModeTitle = document.querySelector<HTMLElement>("[data-category-mode-title]");
  const homeSubtitleModes = [
    "konkret",
    "przepis",
    "pomysły",
    "decyzję"
  ];
  let touchStartY = 0;
  let touchStartX = 0;
  let homeSubtitleModeIndex = 0;

  function isMobileViewport() {
    return window.matchMedia("(max-width: 959px)").matches;
  }

  function getResultLabel(count: number) {
    return `${count} ${count === 1 ? "wynik" : "wyniki"}`;
  }

  function rotateHomeSubtitleMode() {
    if (!homeSubtitleMode || !homeSubtitleCurrent || !homeSubtitleNext) return;

    window.setInterval(() => {
      homeSubtitleModeIndex = (homeSubtitleModeIndex + 1) % homeSubtitleModes.length;
      const nextMode = homeSubtitleModes[homeSubtitleModeIndex];

      homeSubtitleNext.textContent = nextMode;
      homeSubtitleMode.classList.add("is-changing");

      window.setTimeout(() => {
      homeSubtitleCurrent.textContent = nextMode;
      homeSubtitleNext.textContent = "";
      homeSubtitleMode.classList.remove("is-changing");
      }, 780);
    }, 5500);
  }

  function createDecisionSurface(surface: HTMLElement) {
    const query = surface.querySelector<HTMLInputElement>("[data-home-query]");
    const form = surface.querySelector<HTMLFormElement>("[data-home-search]");
    const resultsSection = surface.querySelector<HTMLElement>("[data-results-section]");
    const results = [...surface.querySelectorAll<HTMLElement>("[data-home-result]")];
    const resultList = surface.querySelector<HTMLElement>("[data-result-list]");
    const count = surface.querySelector<HTMLElement>("[data-home-count]");
    const tags = surface.querySelector<HTMLElement>("[data-map-tags]");
    const empty = surface.querySelector<HTMLElement>("[data-home-empty]");
    const suggestions = surface.querySelector<HTMLElement>("[data-home-suggestions]");
    const searchMode = surface.querySelector<HTMLInputElement>("[data-search-mode]");
    const mapMode = surface.querySelector<HTMLInputElement>("[data-map-mode]");
    const viewport = surface.querySelector<HTMLElement>("[data-carousel-viewport]");
    const upBtn = surface.querySelector<HTMLButtonElement>("[data-carousel-up]");
    const downBtn = surface.querySelector<HTMLButtonElement>("[data-carousel-down]");
    const cardById = new Map(results.map((card) => [card.dataset.recipeId, card]));
    const isMobileSurface = surface.dataset.decisionSurface === "mobile";
    let debounceId: number | undefined;

    function getVisibleCards() {
      return results.filter((item) => !item.classList.contains("is-hidden"));
    }

    function getCardScrollStep() {
      const cards = getVisibleCards();
      return (cards[0]?.offsetHeight ?? 128) + 12;
    }

    function updateArrows() {
      if (!viewport || !upBtn || !downBtn) return;

      const atTop = viewport.scrollTop <= 2;
      const atBottom = viewport.scrollTop + viewport.clientHeight >= viewport.scrollHeight - 2;
      upBtn.classList.toggle("is-visible", !atTop);
      downBtn.classList.toggle("is-visible", !atBottom);
    }

    function renderSuggestions(items: string[]) {
      if (!suggestions) return;

      suggestions.innerHTML = "";
      suggestions.toggleAttribute("hidden", items.length === 0);

      items.forEach((item) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "suggestion-chip";
        button.textContent = item;
        button.addEventListener("click", () => {
          if (query) query.value = item;
          applyFilter(item);
          query?.focus();
        });
        suggestions.append(button);
      });
    }

    function applyFilter(term = "", options: { scrollToResults?: boolean } = {}) {
      const hasQuery = term.trim().length > 0;
      const searchResult = recipeSearch.search({ query: term, sort: hasQuery ? "relevance" : "time" });
      const idsToShow = searchResult.ids.length > 0 ? searchResult.ids : allIds;
      const visibleIds = new Set(idsToShow);

      results.forEach((item) => item.classList.toggle("is-hidden", !visibleIds.has(item.dataset.recipeId ?? "")));
      idsToShow.forEach((id) => {
        const card = cardById.get(id);
        if (card) resultList?.append(card);
      });

      if (count) count.textContent = getResultLabel(idsToShow.length);
      empty?.toggleAttribute("hidden", searchResult.ids.length > 0 || !hasQuery);
      renderSuggestions(searchResult.suggestions);

      if (viewport) {
        viewport.scrollTo({ top: 0, behavior: "smooth" });
        requestAnimationFrame(updateArrows);
      }

      if (options.scrollToResults) {
        resultsSection?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }

    function debounceFilter() {
      window.clearTimeout(debounceId);
      debounceId = window.setTimeout(() => applyFilter(query?.value ?? ""), 150);
    }

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      applyFilter(query?.value ?? "");
      if (isMobileSurface) query?.blur();
    });

    query?.addEventListener("input", debounceFilter);

    surface.querySelectorAll<HTMLButtonElement>("[data-home-chip]").forEach((button) => {
      button.addEventListener("click", () => {
        const value = button.dataset.homeChip ?? "";
        if (query) query.value = value;
        if (searchMode) searchMode.checked = true;
        applyFilter(value);
        query?.focus();
      });
    });

    surface.querySelectorAll<HTMLButtonElement>("[data-map-filter]").forEach((button) => {
      button.addEventListener("click", () => {
        surface.querySelectorAll("[data-map-filter]").forEach((dot) => dot.classList.remove("active"));
        button.classList.add("active");

        const filter = button.dataset.mapFilter ?? "";
        if (query) query.value = "";
        if (mapMode) mapMode.checked = true;
        if (tags) tags.innerHTML = `<span class="map-tag">${filter}</span><span class="map-tag">dopasowane</span>`;
        applyFilter(filter, { scrollToResults: isMobileSurface });
      });
    });

    viewport?.addEventListener("scroll", updateArrows, { passive: true });

    upBtn?.addEventListener("click", () => {
      viewport?.scrollBy({ top: -getCardScrollStep(), behavior: "smooth" });
    });

    downBtn?.addEventListener("click", () => {
      viewport?.scrollBy({ top: getCardScrollStep(), behavior: "smooth" });
    });

    updateArrows();
    window.addEventListener("resize", updateArrows);

    return {
      applyFilter,
      setMapFilter(filter: string) {
        if (query) query.value = "";
        if (mapMode) mapMode.checked = true;
        surface.querySelectorAll("[data-map-filter]").forEach((dot) => {
          dot.classList.toggle("active", dot instanceof HTMLElement && dot.dataset.mapFilter === filter);
        });
        if (tags) tags.innerHTML = `<span class="map-tag">${filter}</span><span class="map-tag">dopasowane</span>`;
        applyFilter(filter, { scrollToResults: isMobileSurface });
      },
      focusSearch() {
        if (searchMode) searchMode.checked = true;
        window.setTimeout(() => query?.focus(), 320);
      },
      showMap() {
        if (mapMode) mapMode.checked = true;
      },
      blur() {
        query?.blur();
      }
    };
  }

  const surfaces = [...document.querySelectorAll<HTMLElement>("[data-decision-surface]")].map(createDecisionSurface);
  const mobileController = mobileSurface ? surfaces.find((_, index) => document.querySelectorAll("[data-decision-surface]")[index] === mobileSurface) : undefined;
  rotateHomeSubtitleMode();

  function openDecision(mode: "search" | "map", filter = "") {
    if (!overlay || !mobileController || !isMobileViewport()) return;

    decisionLauncher?.classList.add("is-expanding");
    overlay.hidden = false;
    overlay.classList.remove("is-closing");
    document.body.classList.add("decision-overlay-open");

    if (filter) {
      mobileController.setMapFilter(filter);
    } else if (mode === "search") {
      mobileController.focusSearch();
    } else {
      mobileController.showMap();
    }

    requestAnimationFrame(() => {
      overlay.classList.add("is-open");
      overlay.scrollTo({ top: 0 });
    });

    window.setTimeout(() => decisionLauncher?.classList.remove("is-expanding"), 320);
  }

  function closeDecision() {
    if (!overlay || overlay.hidden) return;

    mobileController?.blur();
    overlay.classList.remove("is-open");
    overlay.classList.add("is-closing");
    document.body.classList.remove("decision-overlay-open");

    window.setTimeout(() => {
      overlay.classList.remove("is-closing");
      overlay.hidden = true;
    }, 260);
  }

  document.querySelectorAll<HTMLButtonElement>("[data-open-decision]").forEach((button) => {
    button.addEventListener("click", () => {
      openDecision(button.dataset.openDecision === "map" ? "map" : "search", button.dataset.previewFilter ?? "");
    });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-scroll-to-categories]").forEach((button) => {
    button.addEventListener("click", () => {
      document.querySelector<HTMLElement>("[data-categories-section]")?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  categoryModeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const mode = button.dataset.categoryMode ?? "";

      if (categoryModeTitle) categoryModeTitle.textContent = button.dataset.categoryTitle ?? button.textContent ?? "";

      categoryModeButtons.forEach((item) => {
        const isActive = item === button;
        item.classList.toggle("is-active", isActive);
        item.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      categoryPanels.forEach((panel) => {
        const isActive = panel.dataset.categoryPanel === mode;
        panel.classList.toggle("is-active", isActive);
        panel.toggleAttribute("hidden", !isActive);
      });
    });
  });

  overlay?.querySelector<HTMLButtonElement>("[data-close-decision]")?.addEventListener("click", closeDecision);

  overlay?.addEventListener("touchstart", (event) => {
    touchStartY = event.touches[0]?.clientY ?? 0;
    touchStartX = event.touches[0]?.clientX ?? 0;
  }, { passive: true });

  overlay?.addEventListener("touchend", (event) => {
    const touch = event.changedTouches[0];
    if (!touch) return;

    const deltaY = touch.clientY - touchStartY;
    const deltaX = Math.abs(touch.clientX - touchStartX);
    if (deltaY > 90 && deltaX < 60 && overlay.scrollTop < 12) {
      closeDecision();
    }
  }, { passive: true });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeDecision();
  });

  window.addEventListener("resize", () => {
    if (!isMobileViewport()) closeDecision();
  });
</script>

