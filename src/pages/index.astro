---
import { DiscoveryExperience } from '@/components/DiscoveryExperience';
import SiteHeader from '@/components/SiteHeader.astro';
import { prototypeRecipes } from '@/data/prototype-recipes';
import { defaultLocale } from '@/i18n/config';
import { getMessages } from '@/i18n/messages';
import BaseLayout from '@/layouts/BaseLayout.astro';
import './home-page.css';

const messages = getMessages(defaultLocale);
---

<BaseLayout
  title={messages.home.meta.title}
  description={messages.home.meta.description}
  locale={defaultLocale}
>
  <SiteHeader messages={messages.common} />

  <main>
    <div class="intro-screen">
      <div class="home-hero-bg" aria-hidden="true">
        {messages.home.backgroundPhrases.map((phrase) => <span>{phrase}</span>)}
      </div>

      <section class="home-hero" aria-labelledby="main-heading">
        <h1 id="main-heading">{messages.home.hero.lead} <span>{messages.home.hero.emphasis}</span></h1>
      </section>

      <section class="path-panel" aria-labelledby="paths-heading">
        <p class="path-pill">{messages.home.paths.eyebrow}</p>
        <h2 id="paths-heading">{messages.home.paths.heading}</h2>

        <svg
          class="path-tree"
          viewBox="0 0 300 136"
          preserveAspectRatio="xMidYMid meet"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="tree-gradient-map" x1="0" y1="52" x2="0" y2="124" gradientUnits="userSpaceOnUse">
              <stop class="tree-gradient-start tree-gradient-start--map" offset="0" />
              <stop class="tree-gradient-end--map" offset="1" />
            </linearGradient>
            <linearGradient id="tree-gradient-search" x1="0" y1="52" x2="0" y2="124" gradientUnits="userSpaceOnUse">
              <stop class="tree-gradient-start tree-gradient-start--search" offset="0" />
              <stop class="tree-gradient-end--search" offset="1" />
            </linearGradient>
            <linearGradient id="tree-gradient-categories" x1="0" y1="52" x2="0" y2="124" gradientUnits="userSpaceOnUse">
              <stop class="tree-gradient-start tree-gradient-start--categories" offset="0" />
              <stop class="tree-gradient-end--categories" offset="1" />
            </linearGradient>
          </defs>
          <path class="tree-line tree-line--map" d="M150 52 C150 90 50 74 50 124" />
          <path class="tree-line tree-line--search" d="M150 52 L150 124" />
          <path class="tree-line tree-line--categories" d="M150 52 C150 90 250 74 250 124" />
          <circle class="tree-dot tree-dot--map" cx="50" cy="124" r="5" />
          <circle class="tree-dot tree-dot--search" cx="150" cy="124" r="5" />
          <circle class="tree-dot tree-dot--categories" cx="250" cy="124" r="5" />
          <circle class="tree-node-glow" cx="150" cy="30" r="30" />
          <circle class="tree-node" cx="150" cy="30" r="22" />
          <g class="tree-node-icon">
            <g transform="translate(-2 0) rotate(-37.5 150 30)">
              <rect x="145.5" y="13.5" width="1.8" height="9" rx="0.9" />
              <rect x="149.1" y="13.5" width="1.8" height="9" rx="0.9" />
              <rect x="152.7" y="13.5" width="1.8" height="9" rx="0.9" />
              <path d="M145 22H155C153.5 24.5 151.3 25 151.3 27.5V45.5Q151.3 46.8 150 46.8T148.7 45.5V27.5C148.7 25 146.5 24.5 145 22Z" />
            </g>
            <g transform="translate(2 2) rotate(37.5 150 30)">
              <ellipse cx="150" cy="18" rx="6" ry="7" />
              <path d="M148.8 24H151.2V43.5Q151.2 44.8 150 44.8T148.8 43.5Z" />
            </g>
          </g>
        </svg>

        <div class="path-grid">
          <article class="path-col path-col--map">
            <p class="path-title">{messages.home.paths.mapLead}</p>
            <span class="path-rule" aria-hidden="true"></span>
            <div class="path-action">
              <button class="path-tile" type="button" data-discovery-mode="map">
                <span class="path-icon" aria-hidden="true">
                  <svg viewBox="0 0 48 48">
                    <path
                      class="path-icon-pin"
                      d="M24 7 C16.8 7 11 12.8 11 20 C11 29.5 24 41 24 41 C24 41 37 29.5 37 20 C37 12.8 31.2 7 24 7 Z"
                    />
                    <circle class="path-icon-pin-dot" cx="24" cy="20" r="4.5" />
                  </svg>
                </span>
                <span class="path-tile-label">{messages.home.paths.mapAction}</span>
              </button>
            </div>
          </article>

          <article class="path-col path-col--search">
            <p class="path-title">{messages.home.paths.searchLead}</p>
            <span class="path-rule" aria-hidden="true"></span>
            <div class="path-action">
              <button class="path-tile" type="button" data-discovery-mode="search">
                <span class="path-icon" aria-hidden="true">
                  <svg viewBox="0 0 48 48">
                    <circle class="path-icon-lens" cx="21" cy="21" r="11" />
                    <line class="path-icon-handle" x1="29" y1="29" x2="38" y2="38" />
                  </svg>
                </span>
                <span class="path-tile-label">{messages.home.paths.searchAction}</span>
              </button>
            </div>
          </article>

          <article class="path-col path-col--categories">
            <p class="path-title">{messages.home.paths.categoriesLead}</p>
            <span class="path-rule" aria-hidden="true"></span>
            <div class="path-action">
              <a class="path-tile" href="#kategorie">
                <span class="path-icon" aria-hidden="true">
                  <svg viewBox="0 0 48 48">
                    <rect class="path-icon-cell" x="9" y="9" width="13" height="13" rx="3.5" />
                    <rect class="path-icon-cell path-icon-cell--soft" x="26" y="9" width="13" height="13" rx="3.5" />
                    <rect class="path-icon-cell path-icon-cell--soft" x="9" y="26" width="13" height="13" rx="3.5" />
                    <rect class="path-icon-cell" x="26" y="26" width="13" height="13" rx="3.5" />
                  </svg>
                </span>
                <span class="path-tile-label">{messages.home.paths.categoriesAction}</span>
              </a>
            </div>
          </article>
        </div>

        <p class="path-note">
          <strong>{messages.home.paths.noteLead}</strong> {messages.home.paths.noteBody}
        </p>
      </section>
    </div>

    <DiscoveryExperience
      recipes={prototypeRecipes}
      common={messages.common}
      messages={messages.experience}
      locale={defaultLocale}
      client:load
    />
  </main>

  <footer class="home-footer">
    <p>{messages.home.footer}</p>
  </footer>
</BaseLayout>
