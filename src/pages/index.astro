    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .search-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
  }

  .search-card-header,
  .map-card-header {
