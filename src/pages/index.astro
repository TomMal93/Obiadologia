    align-content: stretch;
    justify-content: stretch;
    padding-block: var(--home-title-offset) 22px;
  }

  .home-hero-copy {
    align-self: start;
    padding: 0;
    border-radius: var(--radius-lg);
    background: transparent;
    border: 0;
    box-shadow: none;
    backdrop-filter: none;
    overflow: hidden;
  }

  .home-hero-copy .home-title {
    padding: 6px 12px 10px;
  }

  .home-subtitle {
    position: relative;
    max-width: 640px;
    margin: 48px auto 0;
    padding: 16px 20px 17px;
    border: 0;
    border-radius: 14px;
    background:
      radial-gradient(circle at 12% 0%, rgba(255, 200, 87, 0.14), transparent 38%),
      linear-gradient(135deg, rgba(255, 253, 248, 0.42), rgba(255, 241, 219, 0.28));
    backdrop-filter: blur(14px) saturate(1.16);
    -webkit-backdrop-filter: blur(14px) saturate(1.16);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      inset 0 0 0 1px rgba(37, 26, 20, 0.025),
      inset 0 -1px 0 rgba(37, 26, 20, 0.04),
      0 10px 26px rgba(37, 26, 20, 0.055);
    color: rgba(37, 26, 20, 0.72);
    font-size: clamp(18px, 4.3vw, 23px);
    font-weight: 650;
    line-height: 1.36;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .home-subtitle::before {
    content: "";
    position: absolute;
    inset: 1px auto auto 1px;
    z-index: 2;
    width: 26px;
    height: 26px;
    border-top: 3px solid rgba(255, 90, 61, 0.58);
    border-left: 3px solid rgba(255, 90, 61, 0.58);
    border-radius: 14px 0 0 0;
    pointer-events: none;
  }

  .home-subtitle::after {
    content: "";
    position: absolute;
    inset: auto 1px 1px auto;
    z-index: 2;
    width: 26px;
    height: 26px;
    border-top: 3px solid rgba(255, 90, 61, 0.58);
    border-left: 3px solid rgba(255, 90, 61, 0.58);
    border-radius: 14px 0 0 0;
    pointer-events: none;
    transform: rotate(180deg);
  }

  .home-subtitle-main {
    position: relative;
    z-index: 1;
    display: block;
  }

  .home-subtitle-rotator {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: baseline;
    gap: 6px;
    width: 100%;
    margin: 12px 0 0;
    padding: 0;
  }

  .home-subtitle-label {
    justify-self: end;
    text-align: right;
    color: var(--text);
    font-size: clamp(17px, 4vw, 21px);
    font-weight: 720;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .home-subtitle-mode {
    position: relative;
    display: inline-grid;
    justify-self: start;
    text-align: left;
    width: 8.4ch;
    min-height: 1.05em;
    overflow: hidden;
    color: #c7432f;
    font-size: clamp(19px, 4.6vw, 24px);
    font-weight: 820;
    line-height: 1.05;
    letter-spacing: 0;
    transform: translateY(0);
    transition: opacity 260ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: opacity, transform;
  }

  .home-subtitle-mode > span {
    grid-area: 1 / 1;
    display: block;
    white-space: nowrap;
    text-align: left;
    will-change: opacity, transform, clip-path;
  }

  .home-subtitle-mode [data-home-subtitle-next] {
    opacity: 0;
    transform: translateX(-115%);
  }

  .home-subtitle-mode::after {
    content: "";
    position: absolute;
    inset: -20% auto -20% -35%;
    width: 36%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.7), transparent);
    opacity: 0;
    transform: skewX(-18deg);
    pointer-events: none;
  }

  .home-subtitle-mode.is-changing [data-home-subtitle-current] {
    animation: subtitleWordCurrentOut 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-subtitle-mode.is-changing [data-home-subtitle-next] {
    animation: subtitleWordNextIn 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-subtitle-mode.is-changing::after {
    animation: subtitleWordSweep 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes subtitleWordCurrentOut {
    0% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
    100% {
      opacity: 0;
      transform: translate3d(44%, 0, 0);
    }
  }

  @keyframes subtitleWordNextIn {
    0% {
      opacity: 0;
      transform: translate3d(-44%, 0, 0);
    }
    35% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes subtitleWordSweep {
    0% {
      opacity: 0;
      left: -36%;
    }
    40% {
      opacity: 0.45;
    }
    100% {
      opacity: 0;
      left: 108%;
    }
  }

  @media (max-width: 430px) {
    .home-subtitle {
      margin-top: 32px;
      padding: 14px 16px 15px;
    }


  }

  .decision-preview {
