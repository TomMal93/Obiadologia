  .axis.slow { right: 7px; top: 50%; transform: translateY(-50%); }
  .axis.light { top: 7px; left: 50%; transform: translateX(-50%); }
  .axis.heavy { bottom: 7px; left: 50%; transform: translateX(-50%); }

  .dot {
    position: absolute;
    width: 18px;
    height: 18px;
    padding: 0;
    border-radius: 999px;
    background: var(--accent);
