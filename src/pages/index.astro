---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import RecipeCard from "@components/RecipeCard.astro";

const recipes = (await getCollection("recipes")).sort((a, b) => a.data.timeMinutes - b.data.timeMinutes);
const searchDocuments = recipes.map(({ id, data }) => ({
  id,
  title: data.title,
  summary: data.summary,
  description: data.description,
  timeMinutes: data.timeMinutes,
  tags: data.tags,
  categories: data.categories,
  mainIngredients: data.mainIngredients,
  searchAliases: data.searchAliases,
  effort: data.effort,
  mood: data.mood,
  cost: data.cost,
  equipment: data.equipment ?? [],
  diet: data.diet ?? []
}));
---

<BaseLayout
  title="Obiadologia - Decyzyjnik obiadowy"
  description="Mobile-first decyzyjnik obiadowy. Wpisz składniki albo wybierz nastrój i szybciej zdecyduj, co dziś ugotować."
>
  <section class="hero home-decision" data-home-decision>
    <div class="home-hero-copy">
      <h1 class="home-title">Co dziś <span>jemy?</span></h1>
    </div>

    <div class="mode">
      <input type="radio" name="mode" id="searchMode" checked />
      <input type="radio" name="mode" id="mapMode" />

      <div class="panels">
        <div class="panel search-panel">
          <div class="search-card">
            <div class="search-card-header">
              <div>
                <h2>Masz trop? Wpisz go tutaj</h2>
                <p>Składnik, smak czy nazwa dania, wszystko działa.</p>
              </div>
            </div>

            <form class="search-box" data-home-search>
              <div class="input-wrap">
                <label class="sr-only" for="home-query">Składniki</label>
                <input id="home-query" data-home-query type="search" placeholder="ryż, tanie, mało zmywania, curry..." autocomplete="off" />
              </div>

              <button type="submit">Szukaj</button>
            </form>

            <div class="chips" aria-label="Szybkie podpowiedzi">
              <button class="chip" type="button" data-home-chip="makaron">mam makaron</button>
              <button class="chip" type="button" data-home-chip="kurczak">coś z kurczakiem</button>
              <button class="chip" type="button" data-home-chip="bez mięsa">bez mięsa</button>
              <button class="chip" type="button" data-home-chip="mało zmywania">mało zmywania</button>
            </div>
          </div>
        </div>

        <div class="panel map-panel">
          <div class="map-card">
            <div class="map-card-header">
              <div>
                <h2>Wskaż klimat na mapie</h2>
                <p>Szybko, lekko czy konkretnie, mapa podpowie.</p>
              </div>
            </div>

            <div class="map-tags" data-map-tags>
              <span class="map-tag">szybko</span>
              <span class="map-tag">konkretnie</span>
              <span class="map-tag">mało garów</span>
            </div>

            <div class="taste-map" aria-label="Mapa smaków">
              <span class="axis fast">szybko</span>
              <span class="axis slow">wolno</span>
              <span class="axis light">lekko</span>
              <span class="axis heavy">konkretnie</span>

              <button class="dot one" type="button" data-map-filter="do 15 minut" aria-label="Szybko i lekko"><span>szybko</span></button>
              <button class="dot two" type="button" data-map-filter="mało zmywania" aria-label="Szybko i konkretnie"><span>patelnia</span></button>
              <button class="dot three" type="button" data-map-filter="bez mięsa" aria-label="Wolniej i lekko"><span>curry</span></button>
              <button class="dot four" type="button" data-map-filter="na dwa dni" aria-label="Wolniej i konkretnie"><span>garnek</span></button>
            </div>

            <a class="open-map" href="/przepisy">Otwórz</a>
          </div>
        </div>
      </div>

      <div class="switch" aria-label="Tryb wyboru obiadu">
        <label for="searchMode">Wyszukiwarka</label>
        <label for="mapMode">Mapa</label>
      </div>
    </div>

    <section class="results" aria-live="polite">
      <div class="results-header">
        <h2>Propozycje</h2>
        <span data-home-count>{recipes.length} wyniki</span>
      </div>

      <div class="carousel-wrap" data-carousel-wrap>
        <button class="carousel-arrow carousel-arrow--up" data-carousel-up aria-label="Przewiń w górę" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
        </button>

        <div class="carousel-viewport" data-carousel-viewport>
          <div class="result-list" data-result-list>
            {recipes.map((recipe, index) => (
              <RecipeCard recipe={recipe} index={index} variant="result" homeResult />
            ))}
          </div>
        </div>

        <button class="carousel-arrow carousel-arrow--down" data-carousel-down aria-label="Przewiń w dół" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>

      <p class="empty-state" data-home-empty hidden>Nie znalazĹ‚em takiego obiadu. SprĂłbuj podobnej frazy.</p>
      <div class="suggestions" data-home-suggestions hidden aria-label="Podpowiedzi wyszukiwania"></div>
    </section>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Wybierz według sytuacji</h2>
      <p>
        Kategorie odpowiadają na realny dzień: mało czasu, mało składników, mało chęci albo obiad na dwa dni.
      </p>
    </div>

    <div class="category-row">
      <a class="category" href="/przepisy?tag=do%2015%20minut">
        <strong>Gotowe w 15 minut</strong>
        <span>ratunek na szybko</span>
      </a>

      <a class="category" href="/przepisy?tag=jednogarnkowe">
        <strong>Jednogarnkowe</strong>
        <span>mniej zmywania</span>
      </a>

      <a class="category" href="/przepisy?tag=na%20dwa%20dni">
        <strong>Na dwa dni</strong>
        <span>obiad plus lunch</span>
      </a>

      <a class="category" href="/przepisy?tag=tanie">
        <strong>Tanie obiady</strong>
        <span>bez dużych zakupów</span>
      </a>
    </div>
  </section>
</BaseLayout>

<script type="application/json" data-recipe-search-docs set:html={JSON.stringify(searchDocuments)}></script>

<script>
  import { createRecipeSearch } from "../lib/recipeSearch";

  const root = document.querySelector<HTMLElement>("[data-home-decision]");
  const query = root?.querySelector<HTMLInputElement>("[data-home-query]");
  const form = root?.querySelector<HTMLFormElement>("[data-home-search]");
  const results = [...(root?.querySelectorAll<HTMLElement>("[data-home-result]") ?? [])];
  const resultList = root?.querySelector<HTMLElement>("[data-result-list]");
  const count = root?.querySelector<HTMLElement>("[data-home-count]");
  const tags = root?.querySelector<HTMLElement>("[data-map-tags]");
  const empty = root?.querySelector<HTMLElement>("[data-home-empty]");
  const suggestions = root?.querySelector<HTMLElement>("[data-home-suggestions]");
  const recipeDocuments = JSON.parse(document.querySelector("[data-recipe-search-docs]")?.textContent ?? "[]");
  const recipeSearch = createRecipeSearch(recipeDocuments);
  const cardById = new Map(results.map((card) => [card.dataset.recipeId, card]));

  // Carousel elements
  const viewport = root?.querySelector<HTMLElement>("[data-carousel-viewport]");
  const upBtn = root?.querySelector<HTMLButtonElement>("[data-carousel-up]");
  const downBtn = root?.querySelector<HTMLButtonElement>("[data-carousel-down]");

  function isMobile() {
    return window.matchMedia("(max-width: 959px)").matches;
  }

  function getVisibleCards() {
    return results.filter((item) => !item.classList.contains("is-hidden"));
  }

  function getCardScrollStep() {
    const cards = getVisibleCards();
    if (cards.length === 0) return 140;
    // Scroll by one card height + gap
    return cards[0].offsetHeight + 12;
  }

  function updateArrows() {
    if (!viewport || !isMobile()) {
      upBtn?.classList.remove("is-visible");
      downBtn?.classList.remove("is-visible");
      return;
    }
    const atTop = viewport.scrollTop <= 2;
    const atBottom = viewport.scrollTop + viewport.clientHeight >= viewport.scrollHeight - 2;
    upBtn?.classList.toggle("is-visible", !atTop);
    downBtn?.classList.toggle("is-visible", !atBottom);
  }

  viewport?.addEventListener("scroll", () => updateArrows(), { passive: true });

  upBtn?.addEventListener("click", () => {
    if (!viewport) return;
    viewport.scrollBy({ top: -getCardScrollStep(), behavior: "smooth" });
  });

  downBtn?.addEventListener("click", () => {
    if (!viewport) return;
    viewport.scrollBy({ top: getCardScrollStep(), behavior: "smooth" });
  });

  function renderSuggestions(items: string[]) {
    if (!suggestions) return;
    suggestions.innerHTML = "";
    suggestions.toggleAttribute("hidden", items.length === 0);

    items.forEach((item) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "suggestion-chip";
      button.textContent = item;
      button.addEventListener("click", () => {
        if (query) query.value = item;
        applyHomeFilter(item);
      });
      suggestions.append(button);
    });
  }

  function applyHomeFilter(term = "") {
    const hasQuery = term.trim().length > 0;
    const searchResult = recipeSearch.search({ query: term, sort: hasQuery ? "relevance" : "time" });
    const visibleIds = new Set(searchResult.ids);

    results.forEach((item) => item.classList.toggle("is-hidden", !visibleIds.has(item.dataset.recipeId ?? "")));
    searchResult.ids.forEach((id) => {
      const card = cardById.get(id);
      if (card) resultList?.append(card);
    });

    const shown = searchResult.ids.length;
    if (count) count.textContent = `${shown} ${shown === 1 ? "wynik" : "wyniki"}`;
    empty?.toggleAttribute("hidden", shown !== 0);
    renderSuggestions(searchResult.suggestions);

    if (viewport && isMobile()) {
      viewport.scrollTo({ top: 0, behavior: "smooth" });
    }
    requestAnimationFrame(() => updateArrows());
  }

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    applyHomeFilter(query?.value ?? "");
  });

  root?.querySelectorAll<HTMLButtonElement>("[data-home-chip]").forEach((button) => {
    button.addEventListener("click", () => {
      if (query) query.value = button.dataset.homeChip ?? "";
      applyHomeFilter(button.dataset.homeChip ?? "");
    });
  });

  root?.querySelectorAll<HTMLButtonElement>("[data-map-filter]").forEach((button) => {
    button.addEventListener("click", () => {
      root.querySelectorAll("[data-map-filter]").forEach((dot) => dot.classList.remove("active"));
      button.classList.add("active");
      const filter = button.dataset.mapFilter ?? "";
      if (tags) tags.innerHTML = `<span class="map-tag">${filter}</span><span class="map-tag">dopasowane</span>`;
      applyHomeFilter(filter);
    });
  });

  // Init arrows
  updateArrows();
  window.addEventListener("resize", () => updateArrows());
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .home-hero-copy {
    padding: 0;
    border-radius: var(--radius-lg);
    background: transparent;
    border: 0;
    box-shadow: none;
    backdrop-filter: none;
    overflow: hidden;
  }

  .home-hero-copy .home-title {
    padding: 38px 12px 30px;
  }

  .mode {
    margin-top: 28px;
    padding: 14px;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  .mode input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .switch {
    width: 100%;
    max-width: 390px;
    margin: 0 auto;
    padding: 7px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 248, 239, 0.7);
  }

  .switch label {
    min-height: 44px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 950;
    transition: 0.2s ease;
    user-select: none;
  }

  #searchMode:checked ~ .switch label[for="searchMode"],
  #mapMode:checked ~ .switch label[for="mapMode"] {
    background: var(--text);
    color: white;
    box-shadow: 0 8px 18px rgba(37, 26, 20, 0.12);
  }

  .panels { margin-top: 0; }
  .panel { display: none; }
  #searchMode:checked ~ .panels .search-panel,
  #mapMode:checked ~ .panels .map-panel { display: block; }

  .panels + .switch {
    margin-top: 14px;
  }

  .search-card,
  .map-card {
    min-height: 220px;
    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  .search-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
  }

  .search-card-header,
  .map-card-header {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
  }

  .search-card-header,
  .map-card-header {
    justify-content: center;
    text-align: center;
  }

  .search-card h2,
  .map-card h2 {
    margin: 0;
    max-width: 220px;
    font-size: 19px;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .search-card h2,
  .map-card h2 {
    max-width: none;
    white-space: nowrap;
    font-size: clamp(17px, 4.9vw, 19px);
  }

  .search-card p,
  .map-card p {
    margin: 7px 0 0;
    max-width: 240px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.35;
  }

  .search-card p,
  .map-card p {
    max-width: none;
    white-space: nowrap;
    font-size: clamp(11px, 3.35vw, 13px);
  }

  .search-card h2,
  .map-card h2,
  .search-card p,
  .map-card p {
    margin-left: auto;
    margin-right: auto;
  }

  .search-box {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 8px;
    border-radius: 22px;
    background: #fff8ef;
    border: 1px solid rgba(37, 26, 20, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.65);
  }

  .input-wrap input {
    width: 100%;
    min-height: 56px;
    border: 0;
    outline: none;
    padding: 15px 16px;
    border-radius: 17px;
    background: transparent;
    color: var(--text);
    font-size: 16px;
    font-weight: 650;
  }

  .input-wrap input::placeholder {
    color: rgba(122, 102, 88, 0.82);
    font-weight: 600;
  }

  .search-box button {
    min-height: 48px;
    padding: 0 18px;
    border-radius: 16px;
    background: var(--accent);
    color: white;
    font-weight: 950;
    box-shadow: 0 14px 30px rgba(255, 90, 61, 0.26);
  }

  .search-card .chips {
    display: none;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding: 0 0 2px;
    scrollbar-width: none;
  }

  .search-card .chips::-webkit-scrollbar { display: none; }

  button.chip {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    background: #fffdf8;
    font-size: 12px;
    font-weight: 850;
  }

  .map-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: visible;
    text-align: center;
  }

  .open-map {
    width: fit-content;
    margin: 0 auto;
    flex: 0 0 auto;
    min-height: 38px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    padding: 0 13px;
    background: var(--text);
    color: white;
    font-size: 12px;
    font-weight: 950;
  }

  .taste-map {
    position: relative;
    width: 100%;
    height: auto;
    aspect-ratio: 2.35 / 1;
    border-radius: 20px;
    background:
      linear-gradient(to right, transparent 49.5%, rgba(37, 26, 20, 0.16) 49.5% 50.5%, transparent 50.5%),
      linear-gradient(to bottom, transparent 49.5%, rgba(37, 26, 20, 0.16) 49.5% 50.5%, transparent 50.5%),
      #fff8ef;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .axis {
    position: absolute;
    font-size: 8px;
    font-weight: 950;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    user-select: none;
  }

  .axis.fast { left: 7px; top: 50%; transform: translateY(-50%); }
  .axis.slow { right: 7px; top: 50%; transform: translateY(-50%); }
  .axis.light { top: 7px; left: 50%; transform: translateX(-50%); }
  .axis.heavy { bottom: 7px; left: 50%; transform: translateX(-50%); }

  .dot {
    position: absolute;
    width: 18px;
    height: 18px;
    padding: 0;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 8px 18px rgba(255, 90, 61, 0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    animation: dotFloat 2.8s ease-in-out infinite alternate;
  }

  .dot span { display: none; }
  .dot.one { left: 25%; top: 28%; }
  .dot.two { left: 23%; bottom: 26%; background: var(--green); animation-delay: -0.6s; }
  .dot.three { right: 26%; top: 32%; background: var(--accent-2); animation-delay: -1.1s; }
  .dot.four { right: 22%; bottom: 24%; animation-delay: -1.7s; }
  .dot.active { transform: scale(1.24); box-shadow: 0 0 0 7px rgba(255, 90, 61, 0.12); }

  .map-tags {
    position: static;
    display: none;
    justify-content: center;
    gap: 7px;
    flex-wrap: wrap;
    max-width: none;
  }

  .map-tag {
    padding: 7px 9px;
    font-size: 11px;
  }

  .results {
    margin-top: 26px;
    text-align: left;
  }

  .results-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
    padding-inline: 4px;
  }

  .results-header h2 {
    margin: 0;
    font-size: 28px;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .results-header span {
    color: var(--muted);
    font-size: 13px;
    font-weight: 850;
    white-space: nowrap;
  }

  /* Carousel wrapper with arrows */
  .carousel-wrap {
    position: relative;
  }

  .carousel-viewport {
    /* 3 cards visible: 3 × card-height + 2 × gap */
    /* card min-height ~142px (118 + padding), gap 12px */
    height: calc(3 * 142px + 2 * 12px);
    overflow-y: auto;
    overflow-x: hidden;
    scroll-behavior: smooth;
    scrollbar-width: none;
    border-radius: 24px;
  }

  .carousel-viewport::-webkit-scrollbar { display: none; }

  .result-list {
    display: grid;
    gap: 12px;
  }

  .empty-state {
    margin: 12px 0 0;
    padding: 14px;
    border-radius: 18px;
    background: rgba(255, 253, 248, 0.88);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 13px;
    font-weight: 850;
    text-align: center;
  }

  .suggestions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .suggestion-chip {
    min-height: 34px;
    padding: 0 11px;
    border-radius: 999px;
    background: var(--text);
    color: white;
    font-size: 12px;
    font-weight: 950;
  }

  /* Arrow buttons at top and bottom */
  .carousel-arrow {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) scale(0.85);
    z-index: 5;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.92);
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(37, 26, 20, 0.12);
    backdrop-filter: blur(10px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.2s ease;
  }

  .carousel-arrow.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) scale(1);
  }

  .carousel-arrow:active {
    transform: translateX(-50%) scale(0.9);
  }

  .carousel-arrow--up {
    top: -20px;
  }

  .carousel-arrow--down {
    bottom: -20px;
  }

  .category-row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(168px, 72%);
    gap: 14px;
    overflow-x: auto;
    padding: 2px 18px 20px;
    margin-inline: -18px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .category-row::-webkit-scrollbar { display: none; }

  .category {
    min-height: 146px;
    padding: 18px;
    border-radius: 24px;
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 14px 38px rgba(37, 26, 20, 0.08);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    scroll-snap-align: start;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .category strong {
    font-size: 21px;
    letter-spacing: -0.045em;
    line-height: 1.02;
  }

  .category span {
    color: var(--muted);
    font-size: 13px;
    font-weight: 850;
  }

  @keyframes dotFloat {
    from { translate: 0 0; }
    to { translate: 0 -3px; }
  }

  @media (min-width: 700px) {
    .home-hero-copy {
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      backdrop-filter: none;
      overflow: visible;
    }

    .home-hero-copy .home-title {
      padding: 0;
    }

    .mode {
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      backdrop-filter: none;
    }

    .search-card,
