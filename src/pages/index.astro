    border: 0;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      inset 0 0 0 1px rgba(37, 26, 20, 0.025),
      inset 0 -1px 0 rgba(37, 26, 20, 0.04),
      0 10px 26px rgba(37, 26, 20, 0.055);
    backdrop-filter: blur(14px) saturate(1.16);
    -webkit-backdrop-filter: blur(14px) saturate(1.16);
    display: grid;
