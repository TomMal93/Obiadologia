    width: 26px;
    height: 26px;
    border-top: 3px solid rgba(255, 90, 61, 0.58);
    border-left: 3px solid rgba(255, 90, 61, 0.58);
    border-radius: 14px 0 0 0;
    pointer-events: none;
    transform: rotate(180deg);
  }

  .home-subtitle-card {
    display: contents;
  }

  .home-subtitle-main {
    position: relative;
    z-index: 1;
    display: block;
  }

  .home-subtitle-rotator {
    position: relative;
    z-index: 1;
    order: 4;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: baseline;
    gap: 6px;
    width: 100%;
    margin: 12px 0 0;
    padding: 0;
  }

  .home-subtitle-label {
    justify-self: end;
    text-align: right;
    color: var(--text);
    font-size: clamp(17px, 4vw, 21px);
    font-weight: 720;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .home-subtitle-mode {
    position: relative;
    display: inline-grid;
    justify-self: start;
    text-align: left;
    width: 8.4ch;
    min-height: 1.05em;
    overflow: hidden;
    color: #c96a57;
    font-size: clamp(19px, 4.6vw, 24px);
    font-weight: 820;
    line-height: 1.05;
    letter-spacing: 0;
    text-shadow:
      0 1px 0 rgba(255, 246, 239, 0.72),
      0 10px 18px rgba(214, 62, 37, 0.14);
    transform: translateY(0);
    transition:
      color 360ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
      text-shadow 360ms cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: opacity, transform;
  }

  .home-subtitle-mode > span {
    grid-area: 1 / 1;
    display: block;
    white-space: nowrap;
    text-align: left;
    will-change: opacity, transform, clip-path;
  }

  .home-subtitle-mode [data-home-subtitle-next] {
    opacity: 0;
    transform: translateX(-115%);
  }

  .home-subtitle-mode::after {
    content: "";
    position: absolute;
    inset: -20% auto -20% -35%;
    width: 36%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.7), transparent);
    opacity: 0;
    transform: skewX(-18deg);
    pointer-events: none;
  }

  .home-subtitle-mode.is-changing [data-home-subtitle-current] {
    animation: subtitleWordCurrentOut 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-subtitle-mode.is-changing [data-home-subtitle-next] {
    animation: subtitleWordNextIn 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .home-subtitle-mode.is-changing::after {
    animation: subtitleWordSweep 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes subtitleWordCurrentOut {
    0% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
    100% {
      opacity: 0;
      transform: translate3d(44%, 0, 0);
    }
  }

  @keyframes subtitleWordNextIn {
    0% {
      opacity: 0;
      transform: translate3d(-44%, 0, 0);
    }
    35% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes subtitleWordSweep {
    0% {
      opacity: 0;
      left: -36%;
    }
    40% {
      opacity: 0.45;
    }
    100% {
      opacity: 0;
      left: 108%;
    }
