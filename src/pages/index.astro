    color: rgba(37, 26, 20, 0.58);
    font-size: 11px;
    font-weight: 780;
    line-height: 1.18;
    text-align: center;
  }

  .decision-cue {
    position: relative;
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    align-items: center;
    align-content: stretch;
    justify-items: center;
    gap: 2px;
    min-height: 88px;
    padding: 14px 7px 0;
    text-wrap: balance;
  }

  .decision-cue > span:not(.decision-cue-arrow) {
    position: relative;
    z-index: 1;
  }

  .decision-cue > span:not(.decision-cue-arrow) {
    display: block;
  }

  .decision-option-list {
    display: grid;
    gap: 8px;
  }

  .decision-option {
    position: relative;
    overflow: hidden;
    min-height: 52px;
    padding: 10px 40px 10px 14px;
    border-radius: 10px;
    background:
      radial-gradient(130% 90% at 18% -28%, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.2) 32%, rgba(255, 255, 255, 0) 58%),
      linear-gradient(118deg, rgba(255, 255, 255, 0) 0 38%, rgba(255, 255, 255, 0.2) 48%, rgba(255, 255, 255, 0.03) 56%, rgba(255, 255, 255, 0) 68%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 253, 248, 0.42)),
      rgba(255, 253, 248, 0.44);
    border: 1px solid rgba(126, 76, 0, 0.3);
    color: var(--text);
    display: grid;
    gap: 2px;
    justify-items: start;
    text-align: left;
    box-shadow:
      0 16px 34px rgba(37, 26, 20, 0.14),
      0 3px 7px rgba(37, 26, 20, 0.09),
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 0 0 1px rgba(37, 26, 20, 0.06),
      inset 0 -1px 0 rgba(37, 26, 20, 0.12);
    backdrop-filter: blur(16px) saturate(1.14);
    -webkit-backdrop-filter: blur(16px) saturate(1.14);
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease;
  }

  .decision-option::before {
    content: "";
    position: absolute;
    inset: 1px;
    z-index: 0;
    border-radius: 9px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.1) 24%, rgba(255, 255, 255, 0) 54%),
      linear-gradient(112deg, rgba(255, 255, 255, 0) 0 34%, rgba(255, 255, 255, 0.12) 43%, rgba(255, 255, 255, 0.42) 50%, rgba(255, 255, 255, 0.12) 57%, rgba(255, 255, 255, 0) 68%),
      radial-gradient(85% 70% at 14% 0%, rgba(255, 255, 255, 0.52), rgba(255, 255, 255, 0) 64%);
    background-size: 100% 100%, 230% 100%, 100% 100%;
    background-position: 0 0, 145% 0, 0 0;
    opacity: 0.72;
    pointer-events: none;
    animation: decision-option-lustre 5.8s ease-in-out infinite;
  }

  .decision-option:nth-child(2)::before {
    animation-delay: 0.55s;
  }

  .decision-option:nth-child(3)::before {
    animation-delay: 1.1s;
  }

  @keyframes decision-option-lustre {
    0% {
      background-position: 0 0, 145% 0, 0 0;
      opacity: 0.62;
    }

    9% {
      opacity: 0.84;
    }

    18% {
      background-position: 0 0, -52% 0, 0 0;
      opacity: 0.58;
    }

    24%,
    100% {
      background-position: 0 0, -52% 0, 0 0;
      opacity: 0.62;
    }
  }

  .decision-option::after {
    content: "→";
    position: absolute;
    z-index: 1;
    top: 50%;
    right: 14px;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    color: rgba(37, 26, 20, 0.9);
    box-shadow:
      inset 0 0 0 1px rgba(37, 26, 20, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    display: grid;
    place-items: center;
    font-size: 13px;
    font-weight: 850;
    line-height: 1;
    transform: translateY(-50%);
  }

  .decision-option span,
  .decision-option strong {
    position: relative;
    z-index: 1;
  }

  .decision-option span {
    font-size: 15px;
    font-weight: 950;
