      transform 250ms ease-in,
      opacity 250ms ease-in;
  }

  .overlay-header {
    min-height: 56px;
    display: grid;
    grid-template-columns: 44px 1fr 44px;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .overlay-close {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.86);
