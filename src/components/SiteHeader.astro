---
// Wspólny nagłówek z logo/brandem, osadzany na stronach Astro poza wyspą React.
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Obiadologia — strona główna">
    <span class="brand-mark" aria-hidden="true">O</span>
    <span>Obiadologia</span>
  </a>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    height: var(--header-block);
    padding: 0 var(--gutter);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--color-text);
    font-size: 20px;
    font-weight: 800;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 14px;
    color: white;
    background: var(--brand-gradient);
    box-shadow: 0 8px 20px rgb(255 79 46 / 24%);
  }
</style>
