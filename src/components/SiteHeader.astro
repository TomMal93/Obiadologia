---
const pathname = Astro.url.pathname;

const items = [
  { href: "/", label: "Strona główna" },
  { href: "/przepisy", label: "Przepisy" },
  { href: "/o-nas", label: "O nas" },
  { href: "/kontakt", label: "Kontakt" }
];
---

<header class="site-header">
  <div class="site-header-bar">
    <a href="/" class="logo" aria-label="Obiadologia - strona główna">
      <span class="logo-mark" aria-hidden="true">🍳</span>
      Obiadologia
    </a>

    <button class="menu-button" type="button" data-menu-button aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-nav">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <nav class="site-nav" aria-label="Główna nawigacja">
      {items.map((item) => (
        <a href={item.href} aria-current={pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href)) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <nav class="mobile-nav" id="mobile-nav" data-mobile-nav aria-label="Mobilna nawigacja" hidden>
    {items.map((item) => (
      <a href={item.href} aria-current={pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href)) ? "page" : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
  const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
  const header = document.querySelector<HTMLElement>(".site-header");
  let closeTimer: number | undefined;

  button?.addEventListener("click", () => {
    if (!nav) return;
    const open = nav.hasAttribute("hidden");
    if (open) {
      window.clearTimeout(closeTimer);
      nav.removeAttribute("hidden");
      header?.classList.add("is-menu-open");
      requestAnimationFrame(() => nav.classList.add("is-open"));
    } else {
      nav.classList.remove("is-open");
      header?.classList.remove("is-menu-open");
      closeTimer = window.setTimeout(() => nav.setAttribute("hidden", ""), 220);
    }
    button.setAttribute("aria-expanded", String(open));
    button.setAttribute("aria-label", open ? "Zamknij menu" : "Otwórz menu");
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 80;
  }

  .site-header::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: calc(var(--site-header-bar-size) + 226px);
    z-index: 0;
    pointer-events: none;
    background: rgba(255, 200, 87, 0.86);
    box-shadow: 0 20px 44px rgba(130, 86, 26, 0.16);
    backdrop-filter: blur(20px) saturate(1.08);
    -webkit-backdrop-filter: blur(20px) saturate(1.08);
    opacity: 0;
    transform: translateX(-50%) translateY(-10px);
    transition:
      opacity 0.2s ease,
      transform 0.24s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-header.is-menu-open::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .site-header-bar {
    height: var(--site-header-bar-size);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 2;
  }

  .mobile-nav {
    position: absolute;
    top: 100%;
    left: 50%;
    width: 100vw;
    z-index: 1;
    padding: 18px max(18px, calc((100vw - var(--container)) / 2 + 18px)) 20px;
    display: grid;
    gap: 2px;
    overflow: hidden;
    background: transparent;
    box-shadow: none;
    opacity: 0;
    transform: translateX(-50%) translateY(-10px);
    transform-origin: top center;
    transition:
      opacity 0.2s ease,
      transform 0.24s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-nav[hidden] {
    display: none;
  }

  .mobile-nav.is-open {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .mobile-nav a {
    min-height: 46px;
    display: grid;
    place-items: center;
    position: relative;
    padding: 0 14px;
    border-radius: 0;
    color: rgba(37, 26, 20, 0.7);
    font-size: 13px;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
    background: transparent;
    opacity: 0;
    transform: translateY(-4px);
    transition:
      color 0.18s ease,
      opacity 0.2s ease,
      transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-nav.is-open a {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav.is-open a:nth-child(1) { transition-delay: 0.03s; }
  .mobile-nav.is-open a:nth-child(2) { transition-delay: 0.06s; }
  .mobile-nav.is-open a:nth-child(3) { transition-delay: 0.09s; }
  .mobile-nav.is-open a:nth-child(4) { transition-delay: 0.12s; }

  .mobile-nav a::after {
    content: none;
  }

  .mobile-nav a[aria-current="page"] {
    color: var(--text);
  }

  .mobile-nav a[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 8px;
    width: 26px;
    height: 2px;
    border-radius: 999px;
    background: rgba(37, 26, 20, 0.48);
    transform: translateX(-50%);
  }

  .mobile-nav a:active {
    color: var(--text);
  }

  .menu-button[aria-expanded="true"] {
    border-radius: 15px;
    background: rgba(255, 253, 248, 0.36);
    box-shadow: 0 10px 24px rgba(130, 86, 26, 0.1);
  }

  @media (min-width: 960px) {
    .site-header-bar {
      position: static;
      height: var(--site-header-bar-size);
    }

    .mobile-nav {
      display: none;
    }
  }
</style>
