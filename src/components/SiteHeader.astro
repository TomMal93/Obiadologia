---
const pathname = Astro.url.pathname;

const items = [
  { href: "/", label: "Strona główna" },
  { href: "/przepisy", label: "Przepisy" },
  { href: "/o-nas", label: "O nas" },
  { href: "/kontakt", label: "Kontakt" }
];
---

<header class="site-header">
  <div class="site-header-bar">
    <a href="/" class="logo" aria-label="Obiadologia - strona główna">
      <span class="logo-mark" aria-hidden="true">🍳</span>
      Obiadologia
    </a>

    <button class="menu-button" type="button" data-menu-button aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-nav">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <nav class="site-nav" aria-label="Główna nawigacja">
      {items.map((item) => (
        <a href={item.href} aria-current={pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href)) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <nav class="mobile-nav" id="mobile-nav" data-mobile-nav aria-label="Mobilna nawigacja" hidden>
    {items.map((item) => (
      <a href={item.href} aria-current={pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href)) ? "page" : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
  const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");

  button?.addEventListener("click", () => {
    if (!nav) return;
    const open = nav.hasAttribute("hidden");
    nav.toggleAttribute("hidden", !open);
    button.setAttribute("aria-expanded", String(open));
    button.setAttribute("aria-label", open ? "Zamknij menu" : "Otwórz menu");
  });
</script>

<style>
  .site-header {
    position: relative;
  }

  .site-header-bar {
    height: var(--site-header-bar-size);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mobile-nav {
    position: fixed;
    top: env(safe-area-inset-top);
    left: 10px;
    right: 10px;
    z-index: 100;
    padding: 6px;
    display: grid;
    gap: 3px;
    border-radius: 0 0 18px 18px;
    background: rgba(255, 253, 248, 0.96);
    border: 1px solid var(--border);
    box-shadow: 0 18px 42px rgba(37, 26, 20, 0.14);
    backdrop-filter: blur(16px);
  }

  .mobile-nav[hidden] {
    display: none;
  }

  .mobile-nav a {
    min-height: 38px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px 0 14px;
    border-radius: 13px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 950;
  }

  .mobile-nav a::after {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: transparent;
  }

  .mobile-nav a[aria-current="page"] {
    background: var(--soft);
    color: var(--text);
  }

  .mobile-nav a[aria-current="page"]::after {
    background: var(--accent);
  }

  .mobile-nav a:active {
    background: var(--soft);
    color: var(--text);
  }

  @media (min-width: 960px) {
    .site-header-bar {
      position: static;
      height: var(--site-header-bar-size);
    }

    .mobile-nav {
      display: none;
    }
  }
</style>
