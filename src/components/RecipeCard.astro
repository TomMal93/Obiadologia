---
import type { CollectionEntry } from "astro:content";

interface Props {
  recipe: CollectionEntry<"recipes">;
  index?: number;
  compact?: boolean;
  variant?: "catalog" | "result" | "category";
  homeResult?: boolean;
  initiallyHidden?: boolean;
  fullWidthContent?: boolean;
}

const {
  recipe,
  index = 0,
  compact = false,
  variant = "catalog",
  homeResult = false,
  initiallyHidden = false,
  fullWidthContent = false
} = Astro.props;
const tone = `tone-${(index % 5) + 1}`;
const href = `/przepisy/${recipe.id}`;
const catalogTags = [
  `${recipe.data.timeMinutes} min`,
  recipe.data.effort,
  recipe.data.mood
].filter(Boolean).slice(0, 3);
const resultTags = [`${recipe.data.timeMinutes} min`, recipe.data.effort].filter(Boolean);
const tags = variant === "result" ? resultTags : catalogTags;
---

<a
  class:list={["recipe-card", `recipe-card--${variant}`, tone, { compact, "is-hidden": initiallyHidden, "full-width-content": fullWidthContent }]}
  href={href}
  data-recipe-card
  data-recipe-id={recipe.id}
  data-home-result={homeResult ? "" : undefined}
  data-title={recipe.data.title.toLowerCase()}
  data-tags={recipe.data.tags.join(" ").toLowerCase()}
  data-categories={recipe.data.categories.join(" ").toLowerCase()}
  data-main-ingredients={recipe.data.mainIngredients.join(" ").toLowerCase()}
  data-time={recipe.data.timeMinutes}
  data-cost={recipe.data.cost}
  data-effort={recipe.data.effort}
  data-mood={recipe.data.mood}
>
  {fullWidthContent ? (
    <>
      <div class="recipe-content">
        <h3>{recipe.data.title}</h3>
        <p>{recipe.data.summary}</p>
      </div>
      <div class="recipe-footer">
        <div class="meta-row">
          {tags.map((tag) => <span class="meta">{tag}</span>)}
        </div>
        {(variant === "catalog" || variant === "category") && <span class="recipe-action">Zobacz przepis</span>}
      </div>
    </>
  ) : (
    <>
      <div class="meta-row">
        {tags.map((tag) => <span class="meta">{tag}</span>)}
      </div>
      <div class="recipe-content">
        <h3>{recipe.data.title}</h3>
        <p>{recipe.data.summary}</p>
        {(variant === "catalog" || variant === "category") && <span class="recipe-action">Zobacz przepis</span>}
      </div>
    </>
  )}
  <div class="recipe-thumb" aria-hidden="true"></div>
</a>

<style>
  .recipe-card {
    min-height: 154px;
    padding: 12px;
    display: grid;
    grid-template-columns: 1fr 106px;
    gap: 12px;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: rgba(255, 253, 248, 0.88);
    box-shadow: 0 12px 34px rgba(37, 26, 20, 0.08);
    backdrop-filter: blur(14px);
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.18s ease;
  }

  .recipe-content {
    min-width: 0;
  }

  .recipe-card.full-width-content {
    grid-template-columns: 1fr;
  }

  .recipe-card.full-width-content .recipe-content {
    width: 100%;
  }

  .recipe-footer {
    grid-column: 1 / -1;
  }

  .recipe-card.full-width-content .recipe-thumb {
    display: none;
  }

  .meta-row {
    grid-column: 1 / -1;
    margin-bottom: 9px;
  }

  .recipe-card h3 {
    margin: 0;
    font-size: 21px;
    letter-spacing: -0.045em;
    line-height: 1.02;
  }

  .recipe-card p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recipe-action {
    display: inline-grid;
    min-height: 34px;
    margin-top: 12px;
    padding: 0 11px;
    border-radius: 999px;
    font-size: 12px;
  }

  .recipe-thumb {
    width: 106px;
    height: 112px;
  }

  .recipe-card.is-hidden {
    display: none;
  }

  .recipe-card--result {
    min-height: 118px;
    grid-template-columns: 1fr 104px;
  }

  .recipe-card--result .meta-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .recipe-card--result h3 {
    font-size: 20px;
  }

  .recipe-card--result p {
    margin-top: 7px;
  }

  .recipe-card--result .recipe-thumb {
    width: 104px;
    height: 94px;
  }

  .recipe-card--category {
    --recipe-rgb: 255, 90, 61;
    --recipe-top: rgba(255, 255, 255, 0.62);
    --recipe-lift: rgba(var(--recipe-rgb), 0.13);
    --recipe-depth: rgba(var(--recipe-rgb), 0.055);
    --recipe-glass-edge: rgba(var(--recipe-rgb), 0.14);
    --recipe-border: rgba(var(--recipe-rgb), 0.28);
    --recipe-border-hover: rgba(var(--recipe-rgb), 0.42);
    --recipe-text: #9a4a35;
    --recipe-text-shadow: rgba(255, 246, 239, 0.72);
  }

  .recipe-card--category.tone-2,
  .recipe-card--category.tone-5 {
    --recipe-rgb: 255, 200, 87;
    --recipe-border: rgba(224, 151, 22, 0.5);
    --recipe-border-hover: rgba(224, 151, 22, 0.66);
    --recipe-text: #80601a;
    --recipe-text-shadow: rgba(255, 251, 233, 0.76);
  }

  .recipe-card--category.tone-3 {
    --recipe-rgb: 47, 143, 91;
    --recipe-text: #31764b;
    --recipe-text-shadow: rgba(245, 255, 248, 0.72);
  }

  .recipe-card--category.tone-4 {
    --recipe-rgb: 32, 137, 230;
    --recipe-text: #2f76a8;
    --recipe-text-shadow: rgba(242, 249, 255, 0.72);
  }

  .recipe-card--category .recipe-action {
    display: none;
  }

  @media (min-width: 700px) {
    .recipe-card:not(.compact) {
      grid-template-columns: 1fr;
    }

    .recipe-card:not(.compact) .recipe-thumb {
      width: 100%;
      height: 142px;
      order: -1;
    }

    .recipe-card--result:not(.compact) {
      grid-template-columns: 1fr 136px;
      min-height: 132px;
    }

    .recipe-card--result:not(.compact) .recipe-thumb {
      width: 136px;
      height: 108px;
      order: initial;
    }

    .recipe-card--result h3 {
      font-size: 24px;
    }

    .recipe-card--result p {
      font-size: 14px;
    }
  }

  @media (min-width: 960px) {
    .recipe-card--result:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 699px) {
    .recipe-card--category {
      position: relative;
      isolation: isolate;
      min-height: 148px;
      padding: 13px 10px 12px;
      grid-template-columns: 1fr;
      grid-template-rows: auto minmax(0, 1fr) auto;
      align-content: stretch;
      place-items: center;
      gap: 7px;
      overflow: hidden;
      border: 1.5px solid var(--recipe-border);
      border-radius: 13px;
      background:
        radial-gradient(120% 95% at 18% 0%, rgba(var(--recipe-rgb), 0.12), transparent 50%),
        linear-gradient(160deg, rgba(255, 255, 255, 0.58), rgba(255, 253, 248, 0.32)),
        rgba(255, 253, 248, 0.28);
      box-shadow:
        0 12px 22px rgba(37, 26, 20, 0.07),
        0 2px 6px rgba(37, 26, 20, 0.045),
        0 1px 0 var(--recipe-lift),
        0 0 0 1px rgba(255, 255, 255, 0.42),
        inset 0 1px 0 var(--recipe-top),
        inset 0 0 0 1px var(--recipe-glass-edge),
        inset 0 -12px 18px var(--recipe-depth);
      text-align: center;
      backdrop-filter: blur(18px) saturate(1.12);
      -webkit-backdrop-filter: blur(18px) saturate(1.12);
    }

    .recipe-card--category::before {
      content: "";
      position: absolute;
      inset: 1px;
      z-index: 0;
      border-radius: 12px;
      background:
        radial-gradient(70% 58% at 22% 4%, var(--recipe-top), transparent 62%),
        linear-gradient(112deg, transparent 0 30%, rgba(255, 255, 255, 0.18) 42%, rgba(255, 255, 255, 0.42) 50%, rgba(255, 255, 255, 0.18) 58%, transparent 72%);
      background-size: 100% 100%, 240% 100%;
      background-position: 0 0, 145% 0;
      opacity: 0.58;
      pointer-events: none;
      animation: recipe-card-lustre 8s ease-in-out infinite;
    }

    .recipe-card--category::after {
      content: "";
      position: absolute;
      inset: 8px;
      z-index: 0;
      border: 1px solid rgba(var(--recipe-rgb), 0.24);
      border-radius: 8px;
      pointer-events: none;
    }

    .recipe-card--category:nth-child(2n)::before {
      animation-delay: 0.55s;
    }

    .recipe-card--category:nth-child(3n)::before {
      animation-delay: 1.1s;
    }

    .recipe-card--category .recipe-thumb,
    .recipe-card--category .recipe-content,
    .recipe-card--category .recipe-footer,
    .recipe-card--category .meta-row {
      position: relative;
      z-index: 1;
    }

    .recipe-card--category .recipe-thumb {
      display: block;
      order: -2;
      width: 30px;
      height: 30px;
      border-radius: 10px;
      box-shadow: 0 1px 0 rgba(255, 253, 248, 0.72);
    }

    .recipe-card--category.full-width-content .recipe-thumb {
      display: block;
    }

    .recipe-card--category .recipe-thumb::after {
      inset: 8px;
      border-width: 3px;
    }

    .recipe-card--category .recipe-content {
      order: -1;
      display: grid;
      place-items: center;
      align-self: center;
    }

    .recipe-card--category h3 {
      max-width: 10ch;
      color: rgba(37, 26, 20, 0.84);
      font-size: 16px;
      font-weight: 980;
      letter-spacing: 0;
      line-height: 1;
      text-wrap: balance;
      text-shadow: 0 1px 0 rgba(255, 253, 248, 0.76);
    }

    .recipe-card--category p {
      display: none;
    }

    .recipe-card--category .meta-row {
      order: 1;
      margin: 0;
      display: flex;
      justify-content: center;
      gap: 0;
    }

    .recipe-card--category .recipe-footer {
      order: 1;
      grid-column: auto;
      display: block;
      margin: 0;
    }

    .recipe-card--category .meta {
      position: relative;
      min-height: 24px;
      display: inline-grid;
      place-items: center;
      padding: 0 9px;
      border: 1px solid rgba(255, 255, 255, 0.34);
      border-radius: 9px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.16)),
        rgba(255, 253, 248, 0.18);
      color: var(--recipe-text);
      font-size: 11px;
      font-weight: 950;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.58),
        inset 0 0 0 1px rgba(37, 26, 20, 0.035);
      text-shadow: 0 1px 0 var(--recipe-text-shadow);
    }

    .recipe-card--category .meta::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -6px;
      width: min(52px, 74%);
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, transparent, rgba(var(--recipe-rgb), 0.64), transparent);
      transform: translateX(-50%);
      pointer-events: none;
    }

    .recipe-card--category:hover,
    .recipe-card--category:focus-visible {
      border-color: var(--recipe-border-hover);
      box-shadow:
        0 16px 28px rgba(37, 26, 20, 0.09),
        0 4px 8px rgba(37, 26, 20, 0.06),
        0 2px 0 var(--recipe-lift),
        0 0 0 1px rgba(255, 255, 255, 0.5),
        inset 0 1px 0 var(--recipe-top),
        inset 0 0 0 1px var(--recipe-glass-edge),
        inset 0 -12px 18px var(--recipe-depth);
    }

    .recipe-card--category.full-width-content {
      min-height: 0;
      padding: 14px;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      align-items: stretch;
      place-items: stretch;
      gap: 0;
      text-align: left;
    }

    .recipe-card--category.full-width-content .recipe-thumb {
      display: none;
    }

    .recipe-card--category.full-width-content .recipe-content {
      order: 0;
      display: block;
      align-self: auto;
    }

    .recipe-card--category.full-width-content h3 {
      max-width: none;
      font-size: 21px;
      letter-spacing: -0.035em;
      line-height: 1.02;
      text-align: left;
      text-wrap: auto;
    }

    .recipe-card--category.full-width-content p {
      display: none;
    }

    .recipe-card--category.full-width-content .recipe-footer {
      order: 1;
      grid-column: 1;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      justify-content: space-between;
      align-items: stretch;
      gap: 14px;
      margin: 16px 0 0;
    }

    .recipe-card--category.full-width-content .meta-row {
      min-width: 0;
      margin: 0;
      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .recipe-card--category.full-width-content .meta {
      min-height: 24px;
      max-width: 100%;
      padding: 0 9px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .recipe-card--category.full-width-content .meta::after {
      content: none;
    }

    .recipe-card--category.full-width-content .recipe-action {
      display: inline-grid;
      flex: 0 0 auto;
      min-height: calc(3 * 24px + 2 * 6px);
      height: calc(3 * 24px + 2 * 6px);
      margin: 0;
      padding: 0 12px;
      border-radius: 13px;
      font-size: 12px;
      white-space: nowrap;
    }

    .recipe-card.full-width-content:not(.recipe-card--category) {
      grid-template-columns: 1fr;
    }

    .recipe-card.full-width-content:not(.recipe-card--category) .recipe-footer {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin: 12px 0 0;
    }

    .recipe-card.full-width-content:not(.recipe-card--category) .meta-row {
      min-width: 0;
      flex: 1 1 auto;
      margin: 0;
      gap: 0;
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: start;
      justify-content: start;
    }

    .recipe-card.full-width-content:not(.recipe-card--category) .meta {
      padding: 0;
      background: transparent;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .recipe-card.full-width-content:not(.recipe-card--category) .meta:not(:last-child)::after {
      content: none;
    }

    .recipe-card.full-width-content:not(.recipe-card--category) .recipe-action {
      flex: 0 0 auto;
      width: max-content;
      min-height: 0;
      height: calc(3 * 12px * 1.35);
      align-self: flex-start;
      margin-top: 0;
    }
  }

  @keyframes recipe-card-lustre {
    0% {
      background-position: 0 0, 145% 0;
      opacity: 0.62;
    }

    9% {
      opacity: 0.84;
    }

    18% {
      background-position: 0 0, -52% 0;
      opacity: 0.58;
    }

    24%,
    100% {
      background-position: 0 0, -52% 0;
      opacity: 0.62;
    }
  }
</style>
