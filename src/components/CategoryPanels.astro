    ]
  }
];

function getRecipeCountLabel(count: number) {
  if (count === 1) return "1 przepis";
  if (count > 1 && count < 5) return `${count} przepisy`;
  return `${count} przepisów`;
}

function getRecipeSearchText(recipe: CollectionEntry<"recipes">) {
  return [
    recipe.data.title,
    recipe.data.summary,
    recipe.data.description,
    recipe.data.effort,
    recipe.data.mood,
    recipe.data.cost,
    ...recipe.data.tags,
    ...recipe.data.mainIngredients,
    ...recipe.data.searchAliases
  ].join(" ").toLowerCase();
}

function matchesCategoryFilter(recipe: CollectionEntry<"recipes">, filter: CategoryFilter) {
  if (filter.type === "all") return true;
  if (filter.type === "tag") return recipe.data.tags.includes(filter.value);

  return getRecipeSearchText(recipe).includes(filter.value.toLowerCase());
}

function getCategoryHref(filter: CategoryFilter) {
  if (filter.type === "all") return "/przepisy";

  const param = filter.type === "tag" ? "tag" : "q";
  return `/przepisy?${param}=${encodeURIComponent(filter.value)}`;
}

function getCategoryIcon(icon: string) {
  const path = categoryIconPaths[icon] ?? categoryIconPaths.all;
  return `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="#9a4a35" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}

function buildCategoryMode(mode: CategoryModeConfig): CategoryMode {
  return {
    ...mode,
    tiles: mode.tiles.map((tile) => {
      const count = recipes.filter((recipe) => matchesCategoryFilter(recipe, tile.filter)).length;

      return {
        ...tile,
        href: getCategoryHref(tile.filter),
        countLabel: getRecipeCountLabel(count)
      };
    })
  };
}

const categoryModes = categoryModeConfigs.map(buildCategoryMode);
const initialMode = categoryModes[0];

function getCategoryPanelPlaceholders(tileCount: number) {
  return Array.from({ length: Math.max(0, categoryPanelTileCount - tileCount) });
}

function getCategoryRowTone(index: number) {
  const rowTones = ["sun", "tomato", "leaf"] as const;
  return rowTones[Math.floor(index / 2) % rowTones.length];
}
---

<section class="section screen-section" id="tryby" data-categories-section data-category-panels-root>
  <div class="section-head">
    <h2>Wybierz <span>tryb</span></h2>
  </div>

  <div class="category-frame category-frame--modes">
    <p class="category-mode-intro">Zacznij od sytuacji. Każdy tryb podmienia zestaw skrótów poniżej.</p>

    <div class="category-mode-picker" role="tablist" aria-label="Tryby sytuacji">
      {categoryModes.map((mode, index) => (
        <button
          class:list={["category-mode", { "is-active": index === 0 }]}
          type="button"
          role="tab"
          id={`category-mode-${mode.id}`}
          aria-selected={index === 0 ? "true" : "false"}
          aria-controls={`category-panel-${mode.id}`}
          data-category-mode={mode.id}
          data-category-title={mode.title}
        >
          {mode.title}
        </button>
      ))}
      {placeholderModes.map((mode) => (
        <button
          class:list={[
            "category-mode",
            "category-mode--placeholder",
            `category-mode--placeholder-${mode.mobileSlot}`
          ]}
          type="button"
          disabled
          aria-disabled="true"
        >
          {mode.title}
        </button>
      ))}
    </div>

    <div class="category-mode-summary" aria-live="polite">
      <span>Wybrano</span>
      <strong data-category-mode-title>{initialMode.title}</strong>
    </div>

    <div class="category-panels">
      <div class="category-mode-action">
        <p>Teraz wybierz konkretny skrót do przepisów.</p>
      </div>

      {categoryModes.map((mode, index) => (
        <div
          class:list={["category-panel", { "is-active": index === 0 }]}
          id={`category-panel-${mode.id}`}
          role="tabpanel"
          aria-labelledby={`category-mode-${mode.id}`}
          data-category-panel={mode.id}
          hidden={index !== 0}
        >
          <p class="category-panel-helper">{mode.helper}</p>
          <div class="category-row">
            {mode.tiles.map((category, categoryIndex) => (
              <a class:list={["category", `category--${getCategoryRowTone(categoryIndex)}`]} href={category.href} aria-label={`${category.title}: ${category.label}`}>
                <span class="category-icon" aria-hidden="true" set:html={getCategoryIcon(category.icon)} />
                <strong>{category.title}</strong>
                <span class="category-count">{category.countLabel}</span>
              </a>
            ))}
            {getCategoryPanelPlaceholders(mode.tiles.length).map((_, placeholderIndex) => (
              <div class:list={["category", "category--tile-placeholder", `category--${getCategoryRowTone(mode.tiles.length + placeholderIndex)}`]} aria-hidden="true"></div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <span class="category-frame-corner category-frame-corner--bottom-left" aria-hidden="true"></span>
    <span class="category-frame-corner category-frame-corner--bottom-right" aria-hidden="true"></span>
  </div>
</section>

<script>
  const panelRoots = document.querySelectorAll<HTMLElement>("[data-category-panels-root]");

  function setActiveMode(root: HTMLElement, selectedButton: HTMLButtonElement) {
    const selectedMode = selectedButton.dataset.categoryMode ?? "";
    const modeButtons = root.querySelectorAll<HTMLButtonElement>("[data-category-mode]");
    const modePanels = root.querySelectorAll<HTMLElement>("[data-category-panel]");
    const modeTitle = root.querySelector<HTMLElement>("[data-category-mode-title]");

    if (modeTitle) {
      modeTitle.textContent = selectedButton.dataset.categoryTitle ?? selectedButton.textContent ?? "";
    }

    modeButtons.forEach((button) => {
      const isSelected = button === selectedButton;
      button.classList.toggle("is-active", isSelected);
      button.setAttribute("aria-selected", String(isSelected));
    });

    modePanels.forEach((panel) => {
      const isSelected = panel.dataset.categoryPanel === selectedMode;
      panel.classList.toggle("is-active", isSelected);
      panel.toggleAttribute("hidden", !isSelected);
    });
  }

  panelRoots.forEach((root) => {
    root.querySelectorAll<HTMLButtonElement>("[data-category-mode]").forEach((button) => {
      button.addEventListener("click", () => setActiveMode(root, button));
    });
  });
</script>

<style>
  [data-categories-section].screen-section {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    margin-top: 0;
    padding-block: var(--home-title-offset) clamp(24px, 5vh, 52px);
  }

  [data-categories-section] .section-head {
    text-align: center;
  }

  [data-categories-section] .section-head h2 {
    margin: 0 auto;
    max-width: 620px;
    color: var(--accent);
    font-size: clamp(38px, 10.5vw, 64px);
    font-weight: 650;
    line-height: 0.9;
    letter-spacing: -0.08em;
  }

  [data-categories-section] .section-head h2 span {
    color: var(--text);
  }

  .category-frame {
    --category-frame-accent: rgba(255, 90, 61, 0.58);
    position: relative;
    width: min(100%, 760px);
    margin: clamp(20px, 4.5vh, 46px) auto 0;
    padding: clamp(14px, 4vw, 26px);
    border: 1px solid rgba(255, 90, 61, 0.12);
    border-radius: 14px;
    background:
      radial-gradient(120% 80% at 50% -22%, rgba(255, 90, 61, 0.13), transparent 58%),
      radial-gradient(circle at 12% 0%, rgba(255, 200, 87, 0.12), transparent 38%),
      linear-gradient(145deg, rgba(255, 253, 248, 0.66), rgba(255, 241, 219, 0.34)),
      rgba(255, 253, 248, 0.42);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.78),
      inset 0 0 0 1px rgba(255, 255, 255, 0.16),
      inset 0 -1px 0 rgba(37, 26, 20, 0.04),
      0 12px 28px rgba(255, 90, 61, 0.08),
      0 10px 26px rgba(37, 26, 20, 0.04);
    backdrop-filter: blur(14px) saturate(1.16);
    -webkit-backdrop-filter: blur(14px) saturate(1.16);
  }

  .category-frame--modes {
    padding: 10px;
    background: rgba(255, 253, 248, 0.42);
  }

  .category-frame::before,
  .category-frame::after {
    content: "";
    position: absolute;
    z-index: 2;
    width: 32px;
    height: 32px;
    border-top: 3px solid var(--category-frame-accent);
    border-left: 3px solid var(--category-frame-accent);
    border-radius: 14px 0 0 0;
    pointer-events: none;
  }

  .category-frame::before {
    inset: 1px auto auto var(--category-frame-corner-x, 1px);
  }

  .category-frame::after {
    inset: auto var(--category-frame-corner-x, 1px) 1px auto;
    transform: rotate(180deg);
  }

  .category-frame-corner {
    display: none;
    position: absolute;
    z-index: 2;
    width: 32px;
    height: 32px;
    pointer-events: none;
  }

  .category-mode-picker {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 6px;
    width: 100%;
    margin: 0;
    padding: 0;
    justify-self: center;
  }

  .category-mode-picker::-webkit-scrollbar {
    display: none;
  }

  .category-mode-intro {
    margin: 0 4px 12px;
    color: rgba(37, 26, 20, 0.72);
    font-size: clamp(16px, 4vw, 19px);
    font-weight: 650;
    line-height: 1.36;
    letter-spacing: 0;
    text-align: center;
    text-wrap: balance;
  }

  .category-mode-summary {
    margin: 12px 0 0;
    padding: 13px 14px;
    border: 1px solid rgba(255, 90, 61, 0.18);
    border-radius: 16px;
    background:
      radial-gradient(120% 90% at 50% -35%, rgba(255, 90, 61, 0.2), transparent 56%),
      linear-gradient(145deg, rgba(255, 253, 248, 0.86), rgba(255, 241, 219, 0.46)),
      rgba(255, 253, 248, 0.72);
    color: var(--text);
    box-shadow:
      0 12px 24px rgba(255, 90, 61, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.72);
    text-align: center;
  }

  .category-mode-summary span {
    display: block;
    margin-bottom: 4px;
    color: rgba(255, 90, 61, 0.86);
    font-size: 10px;
    font-weight: 950;
    line-height: 1;
    text-transform: uppercase;
  }

  .category-mode-summary strong {
    display: block;
    font-size: 20px;
    font-weight: 980;
    line-height: 1.05;
  }

  .category-mode-action {
    margin: 10px auto 0;
    width: 100%;
    display: grid;
    justify-items: center;
    gap: 5px;
    padding-top: 14px;
    text-align: center;
  }

  .category-mode-action p {
    margin: 0;
    color: rgba(37, 26, 20, 0.72);
    font-size: clamp(16px, 4vw, 19px);
    font-weight: 650;
    line-height: 1.36;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .category-mode {
    min-width: 0;
    min-height: 38px;
    padding: 0 12px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(37, 26, 20, 0.1);
    background:
      linear-gradient(145deg, rgba(255, 253, 248, 0.72), rgba(255, 241, 219, 0.28)),
      rgba(255, 253, 248, 0.62);
    color: rgba(37, 26, 20, 0.66);
    box-shadow:
      0 8px 20px rgba(37, 26, 20, 0.045),
      inset 0 1px 0 rgba(255, 255, 255, 0.62);
    font-size: 11px;
    font-weight: 950;
    line-height: 1.05;
    text-align: center;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .category-mode.is-active {
    background: rgba(37, 26, 20, 0.9);
    border-color: transparent;
    color: white;
    box-shadow:
      0 8px 18px rgba(37, 26, 20, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .category-mode--placeholder {
    color: rgba(37, 26, 20, 0.34);
    cursor: default;
    opacity: 0.72;
  }

  .category-mode:active {
    transform: scale(0.96);
  }

  .category-panels {
    --category-panels-accent: var(--category-frame-accent);
    --category-panels-bg-top: -102px;
    --category-panels-bg-x: -12px;
    --category-panels-min-height: auto;
    --category-frame-padding: 10px;
    position: relative;
    isolation: isolate;
    display: grid;
