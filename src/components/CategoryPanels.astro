  egg: '<path d="M17 14c0 4-2.4 6-5 6s-5-2-5-6c0-3.3 2.1-9 5-9s5 5.7 5 9Z" />',
  chleb: '<path d="M5 11c0-3 2.5-5 7-5s7 2 7 5v7H5z" /><path d="M8 11h.01" /><path d="M12 10h.01" /><path d="M16 11h.01" />',
  ser: '<path d="m5 11 8-5 6 5v7H5z" /><path d="M9 14h.01" /><path d="M14 12h.01" /><path d="M16 16h.01" />',
  gar: '<path d="M6 10h12" /><path d="M8 10v7a3 3 0 0 0 3 3h2a3 3 0 0 0 3-3v-7" /><path d="M9 7h6" /><path d="M4 13h2" /><path d="M18 13h2" />',
