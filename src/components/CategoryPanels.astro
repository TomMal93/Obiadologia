---
import type { CollectionEntry } from "astro:content";

interface Props {
  recipes: CollectionEntry<"recipes">[];
}

type CategoryFilter =
  | { type: "all" }
  | { type: "query" | "tag"; value: string };

type CategoryTone = "blue" | "fire" | "green" | "leaf" | "sun" | "tomato";

interface CategoryTileConfig {
  title: string;
  label: string;
  icon: string;
  tone: CategoryTone;
  filter: CategoryFilter;
}

interface CategoryModeConfig {
  id: string;
  title: string;
  helper: string;
  tiles: CategoryTileConfig[];
}

interface CategoryTile extends CategoryTileConfig {
  href: string;
  countLabel: string;
}

interface CategoryMode extends Omit<CategoryModeConfig, "tiles"> {
  tiles: CategoryTile[];
}

const { recipes } = Astro.props;

const placeholderModes = [] as const;
const categoryPanelTileCount = 6;

const categoryIconPaths: Record<string, string> = {
